+import csv
+
+from fastapi.testclient import TestClient
+
+from services.orders.api import app
+from services.orders.repository import load_orders
+from services.recorded import load_recorded_lines, months_in_range
+from services.statements.vendor_statements import (
+    FIELDNAMES,
+    known_vendors,
+    statement_rows,
+    vendor_statement,
+    write_statements,
+)
+
+FROM_MONTH = "2026-04"
+TO_MONTH = "2026-06"
+
+
+def test_rows_sorted_by_vendor_and_exact_columns():
+    for month in months_in_range(FROM_MONTH, TO_MONTH):
+        rows = statement_rows(month)
+        assert rows, f"expected activity in {month}"
+        vendors = [r["vendor"] for r in rows]
+        assert vendors == sorted(vendors)
+        for row in rows:
+            assert set(row) == {
+                "vendor",
+                "month",
+                "charged_share_cents",
+                "refund_cents",
+                "fee_cents",
+                "net_payout_cents",
+            }
+            assert row["month"] == month
+
+
+def test_share_minus_fee_equals_net_payout():
+    for month in months_in_range(FROM_MONTH, TO_MONTH):
+        for row in statement_rows(month):
+            assert (
+                row["charged_share_cents"] - row["fee_cents"] == row["net_payout_cents"]
+            ), row
+
+
+def test_month_charged_share_matches_recorded_fulfilled_charges():
+    recorded = load_recorded_lines()
+    for month in months_in_range(FROM_MONTH, TO_MONTH):
+        rows = statement_rows(month)
+        total_share = sum(r["charged_share_cents"] for r in rows)
+        fulfilled_total = sum(
+            c.amount.to_cents()
+            for c in recorded.charges
+            if c.month == month and c.status == "fulfilled"
+        )
+        assert total_share == fulfilled_total, month
+
+
+def test_month_refund_matches_recorded_refund_lines_for_cancelled_orders():
+    recorded = load_recorded_lines()
+    for month in months_in_range(FROM_MONTH, TO_MONTH):
+        rows = statement_rows(month)
+        total_refund = sum(r["refund_cents"] for r in rows)
+        cancelled_ids = {
+            c.order_id
+            for c in recorded.charges
+            if c.month == month and c.status == "cancelled"
+        }
+        recorded_refund_total = sum(
+            l.amount.to_cents() for l in recorded.refund_lines if l.order_id in cancelled_ids
+        )
+        assert total_refund == recorded_refund_total, month
+
