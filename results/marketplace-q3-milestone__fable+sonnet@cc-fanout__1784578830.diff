+def test_writer_does_not_modify_existing_exports(tmp_path):
+    csv_files = sorted(EXPORTS_DIR.glob("*.csv"))
+    assert csv_files
+    before = {p: _sha256(p) for p in csv_files}
+
+    write_outbox("2026-04", "2026-06", tmp_path)
+
+    after = {p: _sha256(p) for p in csv_files}
+    assert before == after
