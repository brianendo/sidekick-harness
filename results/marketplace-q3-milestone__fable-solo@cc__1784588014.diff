+from fastapi.testclient import TestClient
+
+from services.orders.api import app
+from services.statements.vendor_statements import monthly_statement_rows
+
+client = TestClient(app)
+
+
+def test_statement_endpoint_matches_csv_figures():
+    for row in monthly_statement_rows("2026-04"):
+        response = client.get(f"/vendors/{row.vendor}/statements/2026-04")
+        assert response.status_code == 200
+        assert response.json() == {
+            "vendor": row.vendor,
+            "month": "2026-04",
+            "charged_share_cents": row.charged_share.to_cents(),
+            "refund_cents": row.refund.to_cents(),
+            "fee_cents": row.fee.to_cents(),
+            "net_payout_cents": row.net_payout.to_cents(),
+        }
+
+
+def test_unknown_vendor_is_404():
+    assert client.get("/vendors/nobody/statements/2026-04").status_code == 404
+
+
+def test_quiet_month_is_zeros_not_an_error():
+    response = client.get("/vendors/northmill/statements/2026-03")
+    assert response.status_code == 200
+    assert response.json() == {
+        "vendor": "northmill",
+        "month": "2026-03",
+        "charged_share_cents": 0,
+        "refund_cents": 0,
+        "fee_cents": 0,
+        "net_payout_cents": 0,
+    }
+
+
+def test_malformed_month_is_rejected():
+    assert client.get("/vendors/northmill/statements/2026-13").status_code == 422
+    assert client.get("/vendors/northmill/statements/april").status_code == 422
+
+
+def test_statement_fee_is_recorded_not_preview():
+    # Policy: statements quote recorded lines; the checkout preview is a
+    # floor estimate and may legitimately differ (docs/accounting.md).
+    total_fees = sum(
+        client.get(f"/vendors/{row.vendor}/statements/2026-04").json()["fee_cents"]
+        for row in monthly_statement_rows("2026-04")
+    )
+    from services.statements.recorded import load_recorded_lines
+
+    recorded_platform_fees = sum(
+        line.amount.to_cents()
+        for line in load_recorded_lines().payout_lines
+        if line.payee == "platform" and line.month == "2026-04"
+    )
+    assert total_fees == recorded_platform_fees
diff -ruN -x .venv -x __pycache__ -x .pytest_cache -x .git -x .claude -x *.egg-info -x .coverage* a/tests/test_vendor_statements.py b/tests/test_vendor_statements.py
--- a/tests/test_vendor_statements.py	1969-12-31 16:00:00
+++ b/tests/test_vendor_statements.py	2026-07-20 16:00:10
@@ -0,0 +1,104 @@
+from libs.money import Money
+from services.statements.recorded import EXPORTS_DIR, load_recorded_lines
+from services.statements.vendor_statements import (
+    monthly_statement_rows,
+    statement_for_vendor,
+    write_statement_files,
+)
+
+Q2 = ["2026-04", "2026-05", "2026-06"]
+
+
+def test_rows_sorted_by_vendor_and_internally_consistent():
+    for month in Q2:
+        rows = monthly_statement_rows(month)
+        assert rows
+        assert [r.vendor for r in rows] == sorted({r.vendor for r in rows})
+        for row in rows:
+            assert row.month == month
+            assert row.charged_share == row.fee + row.net_payout
+
+
+def test_every_cent_of_recorded_lines_is_accounted_for():
+    recorded = load_recorded_lines()
+    for month in Q2:
+        rows = monthly_statement_rows(month)
+
+        def total(figure):
+            amount = Money(0)
+            for row in rows:
+                amount = amount + figure(row)
+            return amount
+
+        fulfilled_charges = Money(0)
+        for c in recorded.charges:
+            if c.month == month and c.status == "fulfilled":
+                fulfilled_charges = fulfilled_charges + c.amount
+        refunds = Money(0)
+        for line in recorded.refund_lines:
+            if line.month == month:
+                refunds = refunds + line.amount
+        vendor_payouts = Money(0)
+        platform_fees = Money(0)
+        for line in recorded.payout_lines:
+            if line.month == month:
+                if line.payee == "platform":
+                    platform_fees = platform_fees + line.amount
+                else:
+                    vendor_payouts = vendor_payouts + line.amount
+
+        assert total(lambda r: r.charged_share) == fulfilled_charges
+        assert total(lambda r: r.refund) == refunds
+        assert total(lambda r: r.net_payout) == vendor_payouts
+        assert total(lambda r: r.fee) == platform_fees
+
+
+def test_refunds_follow_recorded_refund_lines():
+    from services.orders.repository import load_orders
+
+    recorded = load_recorded_lines()
+    orders = {o.id: o for o in load_orders()}
+    for month in Q2:
+        expected: dict[str, Money] = {}
+        for line in recorded.refund_lines:
+            if line.month != month:
+                continue
+            vendor = {i.sku: i.vendor for i in orders[line.order_id].items}[line.sku]
+            expected[vendor] = expected.get(vendor, Money(0)) + line.amount
+        got = {r.vendor: r.refund for r in monthly_statement_rows(month) if r.refund != Money(0)}
+        assert got == expected
+
+
+def test_quiet_month_is_all_zeros():
+    row = statement_for_vendor("northmill", "2026-03")
+    assert row.charged_share == Money(0)
+    assert row.refund == Money(0)
+    assert row.fee == Money(0)
+    assert row.net_payout == Money(0)
+
+
+def test_regeneration_is_deterministic_and_leaves_nightly_artifacts_alone(tmp_path):
+    nightly = {
+        name: (EXPORTS_DIR / name).read_bytes()
+        for name in ("charges.csv", "refund_lines.csv", "payout_lines.csv")
+    }
+    first = write_statement_files("2026-04", "2026-06", out_dir=tmp_path / "a")
+    second = write_statement_files("2026-04", "2026-06", out_dir=tmp_path / "b")
+    assert [p.name for p in first] == ["2026-04.csv", "2026-05.csv", "2026-06.csv"]
+    for a, b in zip(first, second):
+        assert a.read_bytes() == b.read_bytes()
+    for name, before in nightly.items():
+        assert (EXPORTS_DIR / name).read_bytes() == before
+
+
+def test_csv_matches_computed_rows(tmp_path):
+    import csv
+
+    (path,) = write_statement_files("2026-05", "2026-05", out_dir=tmp_path)
+    with path.open(newline="") as f:
+        got = list(csv.DictReader(f))
+    expected = [
+        {k: str(v) for k, v in row.as_csv_row().items()}
+        for row in monthly_statement_rows("2026-05")
+    ]
+    assert got == expected
diff -ruN -x .venv -x __pycache__ -x .pytest_cache -x .git -x .claude -x *.egg-info -x .coverage* a/tests/test_webhook_outbox.py b/tests/test_webhook_outbox.py
--- a/tests/test_webhook_outbox.py	1969-12-31 16:00:00
+++ b/tests/test_webhook_outbox.py	2026-07-20 16:00:27
@@ -0,0 +1,100 @@
+import hashlib
+import hmac
+import json
+
+from services.notifications.outbox import (
+    build_events,
+    load_subscriptions,
+    sign_payload,
+    write_outbox,
+)
+from services.statements.recorded import load_recorded_lines
+
+EVENT_RANK = {
+    "order.cancelled": 0,
+    "order.fulfilled": 1,
+    "payout.recorded": 2,
+    "refund.recorded": 3,
+}
+
+
+def _sort_key(event, payload):
+    party = payload.get("payee", payload.get("sku", ""))
+    return (payload["charged_at"], payload["order_id"], EVENT_RANK[event], party)
+
+
+def test_events_cover_all_recorded_lines_in_range():
+    recorded = load_recorded_lines()
+    events = build_events(recorded, "2026-04", "2026-06")
+    fulfilled = sum(1 for c in recorded.charges if c.status == "fulfilled")
+    cancelled = sum(1 for c in recorded.charges if c.status == "cancelled")
+    counts = {}
+    for event, _ in events:
+        counts[event] = counts.get(event, 0) + 1
+    assert counts == {
+        "order.fulfilled": fulfilled,
+        "order.cancelled": cancelled,
+        "refund.recorded": len(recorded.refund_lines),
+        "payout.recorded": len(recorded.payout_lines),
+    }
+
+
+def test_events_are_in_deterministic_delivery_order():
+    events = build_events(load_recorded_lines(), "2026-04", "2026-06")
+    keys = [_sort_key(event, payload) for event, payload in events]
+    assert keys == sorted(keys)
+
+
+def test_amounts_come_from_recorded_lines():
+    recorded = load_recorded_lines()
+    events = build_events(recorded, "2026-04", "2026-06")
+    charged = {c.order_id: c for c in recorded.charges}
+    for event, payload in events:
+        if event in ("order.fulfilled", "order.cancelled"):
+            assert payload["charged_cents"] == charged[payload["order_id"]].amount.to_cents()
+        assert payload["charged_at"] == charged[payload["order_id"]].charged_at
+
+
+def test_subset_range_writes_only_that_ranges_events():
+    recorded = load_recorded_lines()
+    q2 = build_events(recorded, "2026-04", "2026-06")
+    april = build_events(recorded, "2026-04", "2026-04")
+    assert april == [e for e in q2 if e[1]["charged_at"].startswith("2026-04")]
+    assert april and len(april) < len(q2)
+
+
+def test_outbox_files_filter_sign_and_reproduce(tmp_path):
+    subscriptions = {s.id: s for s in load_subscriptions()}
+    first = write_outbox("2026-04", "2026-06", out_dir=tmp_path / "a")
+    second = write_outbox("2026-04", "2026-06", out_dir=tmp_path / "b")
+    assert sorted(p.name for p in first) == sorted(f"{sid}.jsonl" for sid in subscriptions)
+    for a, b in zip(first, second):
+        assert a.read_bytes() == b.read_bytes()
+
+    for path in first:
+        subscription = subscriptions[path.stem]
+        for line in path.read_text().splitlines():
+            entry = json.loads(line)
+            assert set(entry) == {"event", "payload", "signature"}
+            assert entry["event"] in subscription.events
+            body = json.dumps(entry["payload"], sort_keys=True, separators=(",", ":"))
+            expected = hmac.new(
+                subscription.secret.encode(), body.encode(), hashlib.sha256
+            ).hexdigest()
+            assert entry["signature"] == expected
+
+
+def test_ops_pager_gets_exactly_the_cancellations(tmp_path):
+    recorded = load_recorded_lines()
+    cancelled = {c.order_id for c in recorded.charges if c.status == "cancelled"}
+    paths = {p.stem: p for p in write_outbox("2026-04", "2026-06", out_dir=tmp_path)}
+    entries = [json.loads(l) for l in paths["ops-pager"].read_text().splitlines()]
+    assert all(e["event"] == "order.cancelled" for e in entries)
+    assert {e["payload"]["order_id"] for e in entries} == cancelled
+
+
+def test_signature_changes_if_payload_tampered():
+    payload = {"order_id": "ORD-4011", "charged_at": "2026-04-01", "charged_cents": 1603}
+    original = sign_payload(payload, "whsec_test")
+    assert sign_payload({**payload, "charged_cents": 1604}, "whsec_test") != original
+    assert sign_payload(payload, "whsec_other") != original
