@@ -0,0 +1,30 @@
+import pytest
+
+from libs.money import Money
+
+
+def test_clamp_raises_to_floor():
+    assert Money(10).clamp(Money(25), Money(120)) == Money(25)
+
+
+def test_clamp_lowers_to_cap():
+    assert Money(200).clamp(Money(25), Money(120)) == Money(120)
+
+
+def test_clamp_inside_bounds_unchanged():
+    assert Money(80).clamp(Money(25), Money(120)) == Money(80)
+
+
+def test_clamp_open_ended_bounds():
+    assert Money(5).clamp(Money(20), None) == Money(20)
+    assert Money(500).clamp(None, Money(90)) == Money(90)
+    assert Money(7).clamp(None, None) == Money(7)
+
+
+def test_clamp_bounds_equal_pins_amount():
+    assert Money(1).clamp(Money(30), Money(30)) == Money(30)
+
+
+def test_clamp_rejects_inverted_bounds():
+    with pytest.raises(ValueError):
+        Money(50).clamp(Money(100), Money(10))
diff -ruN -x .venv -x __pycache__ -x .pytest_cache -x .git -x .claude -x *.egg-info -x .coverage* a/scripts/fee_review.py b/scripts/fee_review.py
--- a/scripts/fee_review.py	1969-12-31 16:00:00
+++ b/scripts/fee_review.py	2026-07-20 17:27:18
@@ -0,0 +1,191 @@
+#!/usr/bin/env python3
+"""Fee-rules what-if review for the pricing team.
+
+Applies the proposed Q3 fee schedule (services/orders/data/fee_rules.json,
+read-only) to the quarter's actual fulfilled orders and reports what each
+rule *would have charged*. This is a review, not a ledger job: it records
+nothing and never modifies the nightly exports.
+
+The base of every fee is the order's recorded charge from
+exports/charges.csv — recorded money lines are authoritative
+(docs/accounting.md); an order's charge is never recomputed from its items.
+
+Usage:
+    python scripts/fee_review.py --from 2026-04 --to 2026-06
+
+Writes exports/fee_review/<YYYY-MM>.csv, one file per month in the
+inclusive range, columns order_id,rule_id,vendor,fee_cents sorted by
+(order_id, vendor). Reruns are byte-identical.
+"""
+from __future__ import annotations
+
+import argparse
+import csv
+import json
+import sys
+from datetime import date
+from pathlib import Path
+
+ROOT = Path(__file__).resolve().parent.parent
+sys.path.insert(0, str(ROOT))
+
+from libs.money import Money  # noqa: E402
+from services.orders.repository import load_orders  # noqa: E402
+
+CHARGES_CSV = ROOT / "exports" / "charges.csv"
+FEE_RULES_JSON = ROOT / "services" / "orders" / "data" / "fee_rules.json"
+DEFAULT_OUT_DIR = ROOT / "exports" / "fee_review"
+
+
+def parse_month(text: str) -> str:
+    """Validate a YYYY-MM month string and return it normalized."""
+    try:
+        year_s, month_s = text.split("-")
+        first_of_month = date(int(year_s), int(month_s), 1)
+    except (ValueError, TypeError):
+        raise argparse.ArgumentTypeError(f"not a YYYY-MM month: {text!r}")
+    return f"{first_of_month.year:04d}-{first_of_month.month:02d}"
+
+
+def month_range(from_month: str, to_month: str) -> list[str]:
+    """Inclusive list of YYYY-MM months from from_month through to_month."""
+    if from_month > to_month:
+        raise ValueError(f"--from {from_month} is after --to {to_month}")
+    months = []
+    year, month = (int(p) for p in from_month.split("-"))
+    while f"{year:04d}-{month:02d}" <= to_month:
+        months.append(f"{year:04d}-{month:02d}")
+        year, month = (year + 1, 1) if month == 12 else (year, month + 1)
+    return months
+
+
+def load_recorded_charges() -> dict[str, dict]:
+    """Recorded charges keyed by order id (authoritative amounts)."""
+    charges = {}
+    with CHARGES_CSV.open(newline="") as f:
+        for row in csv.DictReader(f):
+            charges[row["order_id"]] = {
+                "charged_at": date.fromisoformat(row["charged_at"]),
+                "status": row["status"],
+                "charged": Money.from_cents(int(row["charged_cents"])),
+            }
+    return charges
+
+
+def vendor_goods_values(order) -> dict[str, Money]:
+    """Goods value per vendor, keyed in order of first appearance."""
+    goods: dict[str, Money] = {}
+    for item in order.items:
+        goods[item.vendor] = goods.get(item.vendor, Money(0)) + item.line_total
+    return goods
+
+
+def rule_applies(rule: dict, order, charged_at: date, charged: Money) -> bool:
+    if not (
+        date.fromisoformat(rule["effective_from"])
+        <= charged_at
+        <= date.fromisoformat(rule["effective_to"])
+    ):
+        return False
+    scope = rule.get("scope", {})
+    if "vendors" in scope:
+        vendors = set(scope["vendors"])
+        if not any(item.vendor in vendors for item in order.items):
+            return False
+    if "sku_prefixes" in scope:
+        prefixes = tuple(scope["sku_prefixes"])
+        if not any(item.sku.startswith(prefixes) for item in order.items):
+            return False
+    if "min_order_cents" in scope:
+        if charged.to_cents() < scope["min_order_cents"]:
+            return False
+    return True
+
+
+def winning_rule(rules: list[dict], order, charged_at: date, charged: Money) -> dict | None:
+    applicable = [r for r in rules if rule_applies(r, order, charged_at, charged)]
+    if not applicable:
+        return None
+    return min(applicable, key=lambda r: (-r["priority"], r["id"]))
+
+
+def clamped_fee(base: Money, rule: dict) -> Money:
+    fee = base.percent_of(rule["percent_bps"]) + Money.from_cents(rule.get("fixed_cents", 0))
+    min_fee = rule.get("min_fee_cents")
+    max_fee = rule.get("max_fee_cents")
+    return fee.clamp(
+        Money.from_cents(min_fee) if min_fee is not None else None,
+        Money.from_cents(max_fee) if max_fee is not None else None,
+    )
+
+
+def review_order(order, charged: Money, rule: dict) -> list[tuple[str, Money]]:
+    """(vendor, fee) rows the winning rule produces for one order."""
+    goods = vendor_goods_values(order)
+    vendors = list(goods)
+    weights = [goods[v].to_cents() for v in vendors]
+    if not any(weights):
+        return []
+    if rule["mode"] == "per_order":
+        fee = clamped_fee(charged, rule)
+        if fee == Money(0):
+            return []
+        shares = fee.allocate(weights)
+        return [(v, share) for v, share in zip(vendors, shares) if share != Money(0)]
+    # per_vendor: attribute the recorded charge to vendors (standard
+    # goods-value split), then fee each in-scope vendor's share.
+    attributed = dict(zip(vendors, charged.allocate(weights)))
+    scope_vendors = rule.get("scope", {}).get("vendors")
+    rows = []
+    for vendor in vendors:
+        if scope_vendors is not None and vendor not in scope_vendors:
+            continue
+        fee = clamped_fee(attributed[vendor], rule)
+        if fee != Money(0):
+            rows.append((vendor, fee))
+    return rows
+
+
+def run(from_month: str, to_month: str, out_dir: Path = DEFAULT_OUT_DIR) -> None:
+    months = month_range(from_month, to_month)
+    charges = load_recorded_charges()
+    orders = {o.id: o for o in load_orders()}
+    rules = json.loads(FEE_RULES_JSON.read_text())
+
+    rows_by_month: dict[str, list[tuple]] = {m: [] for m in months}
+    for order_id, charge in charges.items():
+        if charge["status"] != "fulfilled":
+            continue
+        month = charge["charged_at"].isoformat()[:7]
+        if month not in rows_by_month:
+            continue
+        order = orders[order_id]
+        rule = winning_rule(rules, order, charge["charged_at"], charge["charged"])
+        if rule is None:
+            continue
+        for vendor, fee in review_order(order, charge["charged"], rule):
+            rows_by_month[month].append((order_id, rule["id"], vendor, fee.to_cents()))
+
+    out_dir.mkdir(parents=True, exist_ok=True)
+    for month in months:
+        with (out_dir / f"{month}.csv").open("w", newline="") as f:
+            writer = csv.writer(f)
+            writer.writerow(["order_id", "rule_id", "vendor", "fee_cents"])
+            for row in sorted(rows_by_month[month], key=lambda r: (r[0], r[2])):
+                writer.writerow(row)
+
+
+def main(argv: list[str] | None = None) -> int:
+    parser = argparse.ArgumentParser(description=__doc__)
+    parser.add_argument("--from", dest="from_month", type=parse_month, required=True)
+    parser.add_argument("--to", dest="to_month", type=parse_month, required=True)
+    args = parser.parse_args(argv)
+    try:
+        run(args.from_month, args.to_month)
+    except ValueError as exc:
+        parser.error(str(exc))
+    return 0
+
+
+if __name__ == "__main__":
+    sys.exit(main())
diff -ruN -x .venv -x __pycache__ -x .pytest_cache -x .git -x .claude -x *.egg-info -x .coverage* a/scripts/ledger_chain.py b/scripts/ledger_chain.py
--- a/scripts/ledger_chain.py	1969-12-31 16:00:00
+++ b/scripts/ledger_chain.py	2026-07-20 17:28:16
@@ -0,0 +1,199 @@
+#!/usr/bin/env python3
+"""Tamper-evident hash chain over the quarter's recorded money lines.
+
+`build` chains every recorded charge, refund line, and payout line from the
+nightly exports (exports/*.csv, authoritative, read-only) into
+exports/ledger_chain.jsonl, closing each month with a totals record.
+`verify` checks a chain file offline — seq numbering, prev_hash linkage,
+and every hash — with no access to order data.
+
+Usage:
+    python scripts/ledger_chain.py build --from 2026-04 --to 2026-06
+    python scripts/ledger_chain.py verify --file exports/ledger_chain.jsonl
+
+Each record's `hash` is SHA-256 of `prev_hash` + the record serialized as
+compact JSON (sorted keys) with the `hash` field omitted; the first
+record's `prev_hash` is 64 zeros. Reruns of `build` are byte-identical.
+"""
+from __future__ import annotations
+
+import argparse
+import csv
+import hashlib
+import json
+import sys
+from datetime import date
+from pathlib import Path
+
+ROOT = Path(__file__).resolve().parent.parent
+sys.path.insert(0, str(ROOT))
+
+from libs.money import Money  # noqa: E402
+
+CHARGES_CSV = ROOT / "exports" / "charges.csv"
+REFUND_LINES_CSV = ROOT / "exports" / "refund_lines.csv"
+PAYOUT_LINES_CSV = ROOT / "exports" / "payout_lines.csv"
+DEFAULT_OUT_FILE = ROOT / "exports" / "ledger_chain.jsonl"
+
+GENESIS_HASH = "0" * 64
+# `charge` < `payout_line` < `refund_line`: plain lexicographic order.
+MONEY_LINE_KINDS = ("charge", "payout_line", "refund_line")
+
+
+def parse_month(text: str) -> str:
+    """Validate a YYYY-MM month string and return it normalized."""
+    try:
+        year_s, month_s = text.split("-")
+        first_of_month = date(int(year_s), int(month_s), 1)
+    except (ValueError, TypeError):
+        raise argparse.ArgumentTypeError(f"not a YYYY-MM month: {text!r}")
+    return f"{first_of_month.year:04d}-{first_of_month.month:02d}"
+
+
+def month_range(from_month: str, to_month: str) -> list[str]:
+    """Inclusive list of YYYY-MM months from from_month through to_month."""
+    if from_month > to_month:
+        raise ValueError(f"--from {from_month} is after --to {to_month}")
+    months = []
+    year, month = (int(p) for p in from_month.split("-"))
+    while f"{year:04d}-{month:02d}" <= to_month:
+        months.append(f"{year:04d}-{month:02d}")
+        year, month = (year + 1, 1) if month == 12 else (year, month + 1)
+    return months
+
+
+def chain_hash(prev_hash: str, record_without_hash: dict) -> str:
+    body = json.dumps(record_without_hash, sort_keys=True, separators=(",", ":"))
+    return hashlib.sha256((prev_hash + body).encode()).hexdigest()
+
+
+def load_money_lines(months: list[str]) -> list[dict]:
+    """Every recorded money line whose order was charged in the range."""
+    charged_at_by_order: dict[str, str] = {}
+    lines = []
+    with CHARGES_CSV.open(newline="") as f:
+        for row in csv.DictReader(f):
+            charged_at_by_order[row["order_id"]] = row["charged_at"]
+            if row["charged_at"][:7] in months:
+                lines.append(
+                    {
+                        "charged_at": row["charged_at"],
+                        "kind": "charge",
+                        "order_id": row["order_id"],
+                        "party": "",
+                        "amount": Money.from_cents(int(row["charged_cents"])),
+                    }
+                )
+    for path, kind, party_field in (
+        (PAYOUT_LINES_CSV, "payout_line", "payee"),
+        (REFUND_LINES_CSV, "refund_line", "sku"),
+    ):
+        with path.open(newline="") as f:
+            for row in csv.DictReader(f):
+                charged_at = charged_at_by_order[row["order_id"]]
+                if charged_at[:7] not in months:
+                    continue
+                lines.append(
+                    {
+                        "charged_at": charged_at,
+                        "kind": kind,
+                        "order_id": row["order_id"],
+                        "party": row[party_field],
+                        "amount": Money.from_cents(int(row["amount_cents"])),
+                    }
+                )
+    lines.sort(key=lambda l: (l["charged_at"], l["order_id"], l["kind"], l["party"]))
+    return lines
+
+
+def build(from_month: str, to_month: str, out_file: Path = DEFAULT_OUT_FILE) -> None:
+    months = month_range(from_month, to_month)
+    lines = load_money_lines(months)
+
+    records = []
+    prev_hash = GENESIS_HASH
+    seq = 0
+    for month in months:
+        month_lines = [l for l in lines if l["charged_at"][:7] == month]
+        sums = {kind: Money(0) for kind in MONEY_LINE_KINDS}
+        for line in month_lines:
+            record = {
+                "seq": seq,
+                "charged_at": line["charged_at"],
+                "kind": line["kind"],
+                "order_id": line["order_id"],
+                "party": line["party"],
+                "amount_cents": line["amount"].to_cents(),
+                "prev_hash": prev_hash,
+            }
+            record["hash"] = chain_hash(prev_hash, record)
+            prev_hash = record["hash"]
+            seq += 1
+            records.append(record)
+            sums[line["kind"]] = sums[line["kind"]] + line["amount"]
+        close = {
+            "seq": seq,
+            "kind": "month_close",
+            "month": month,
+            "charge_cents": sums["charge"].to_cents(),
+            "refund_cents": sums["refund_line"].to_cents(),
+            "payout_cents": sums["payout_line"].to_cents(),
+            "line_count": len(month_lines),
+            "prev_hash": prev_hash,
+        }
+        close["hash"] = chain_hash(prev_hash, close)
+        prev_hash = close["hash"]
+        seq += 1
+        records.append(close)
+
+    out_file.parent.mkdir(parents=True, exist_ok=True)
+    with out_file.open("w") as f:
+        for record in records:
+            f.write(json.dumps(record, sort_keys=True, separators=(",", ":")) + "\n")
+
+
+def verify(path: Path) -> int:
+    """Check the chain as written; print the verdict and return exit code."""
+    prev_hash = GENESIS_HASH
+    count = 0
+    with path.open() as f:
+        for index, line in enumerate(l for l in f.read().splitlines() if l != ""):
+            try:
+                record = json.loads(line)
+            except json.JSONDecodeError:
+                record = None
+            if (
+                not isinstance(record, dict)
+                or record.get("seq") != index
+                or record.get("prev_hash") != prev_hash
+                or record.get("hash")
+                != chain_hash(prev_hash, {k: v for k, v in record.items() if k != "hash"})
+            ):
+                print(f"BROKEN at seq {index}")
+                return 1
+            prev_hash = record["hash"]
+            count += 1
+    print(f"OK {count} records")
+    return 0
+
+
+def main(argv: list[str] | None = None) -> int:
+    parser = argparse.ArgumentParser(description=__doc__)
+    subparsers = parser.add_subparsers(dest="command", required=True)
+    build_parser = subparsers.add_parser("build")
+    build_parser.add_argument("--from", dest="from_month", type=parse_month, required=True)
+    build_parser.add_argument("--to", dest="to_month", type=parse_month, required=True)
+    verify_parser = subparsers.add_parser("verify")
+    verify_parser.add_argument("--file", type=Path, required=True)
+    args = parser.parse_args(argv)
+    if args.command == "build":
+        try:
+            build(args.from_month, args.to_month)
+        except ValueError as exc:
+            parser.error(str(exc))
+        return 0
+    return verify(args.file)
+
+
+if __name__ == "__main__":
+    sys.exit(main())
diff -ruN -x .venv -x __pycache__ -x .pytest_cache -x .git -x .claude -x *.egg-info -x .coverage* a/scripts/reconcile_bank.py b/scripts/reconcile_bank.py
--- a/scripts/reconcile_bank.py	1969-12-31 16:00:00
+++ b/scripts/reconcile_bank.py	2026-07-20 17:27:49
@@ -0,0 +1,236 @@
+#!/usr/bin/env python3
+"""Bank reconciliation of recorded charges against Paystream settlements.
+
+Reconciles every recorded charge (exports/charges.csv, authoritative;
+fulfilled and cancelled both) in the requested month range against the
+bank file services/orders/data/bank_settlements_q2.csv (read-only).
+Bank amounts are dollar strings parsed digit-by-digit — money never
+passes through a float.
+
+Usage:
+    python scripts/reconcile_bank.py --from 2026-04 --to 2026-06
+
+Writes exports/reconciliation/<YYYY-MM>.csv per month in the inclusive
+range plus exports/reconciliation/summary.json. Reruns are byte-identical.
+"""
+from __future__ import annotations
+
+import argparse
+import csv
+import json
+import re
+import sys
+from datetime import date, timedelta
+from pathlib import Path
+
+ROOT = Path(__file__).resolve().parent.parent
+sys.path.insert(0, str(ROOT))
+
+from libs.money import Money  # noqa: E402
+
+CHARGES_CSV = ROOT / "exports" / "charges.csv"
+BANK_CSV = ROOT / "services" / "orders" / "data" / "bank_settlements_q2.csv"
+DEFAULT_OUT_DIR = ROOT / "exports" / "reconciliation"
+
+SETTLEMENT_WINDOW_DAYS = 3
+STATUSES = (
+    "matched",
+    "amount_mismatch",
+    "late_settlement",
+    "missing_bank",
+    "unknown_ref",
+    "duplicate",
+)
+
+AMOUNT_RE = re.compile(r"(-?)(\d+)\.(\d{2})")
+BANK_REF_RE = re.compile(r"PAYSTREAM-(\d+)")
+
+
+def parse_month(text: str) -> str:
+    """Validate a YYYY-MM month string and return it normalized."""
+    try:
+        year_s, month_s = text.split("-")
+        first_of_month = date(int(year_s), int(month_s), 1)
+    except (ValueError, TypeError):
+        raise argparse.ArgumentTypeError(f"not a YYYY-MM month: {text!r}")
+    return f"{first_of_month.year:04d}-{first_of_month.month:02d}"
+
+
+def month_range(from_month: str, to_month: str) -> list[str]:
+    """Inclusive list of YYYY-MM months from from_month through to_month."""
+    if from_month > to_month:
+        raise ValueError(f"--from {from_month} is after --to {to_month}")
+    months = []
+    year, month = (int(p) for p in from_month.split("-"))
+    while f"{year:04d}-{month:02d}" <= to_month:
+        months.append(f"{year:04d}-{month:02d}")
+        year, month = (year + 1, 1) if month == 12 else (year, month + 1)
+    return months
+
+
+def parse_dollar_amount(text: str) -> Money:
+    """Parse a two-decimal dollar string to Money without touching floats."""
+    match = AMOUNT_RE.fullmatch(text.strip())
+    if match is None:
+        raise ValueError(f"malformed bank amount: {text!r}")
+    sign, dollars, hundredths = match.groups()
+    cents = int(dollars) * 100 + int(hundredths)
+    return Money.from_cents(-cents if sign else cents)
+
+
+def order_id_for_ref(bank_ref: str) -> str | None:
+    match = BANK_REF_RE.fullmatch(bank_ref.strip())
+    return f"ORD-{match.group(1)}" if match else None
+
+
+def load_recorded_charges() -> dict[str, dict]:
+    """Recorded charges keyed by order id (authoritative amounts)."""
+    charges = {}
+    with CHARGES_CSV.open(newline="") as f:
+        for row in csv.DictReader(f):
+            charges[row["order_id"]] = {
+                "charged_at": date.fromisoformat(row["charged_at"]),
+                "charged": Money.from_cents(int(row["charged_cents"])),
+            }
+    return charges
+
+
+def load_bank_rows() -> list[dict]:
+    rows = []
+    with BANK_CSV.open(newline="") as f:
+        for row in csv.DictReader(f):
+            rows.append(
+                {
+                    "txn_id": row["txn_id"],
+                    "settled_on": date.fromisoformat(row["settled_on"]),
+                    "bank_ref": row["bank_ref"],
+                    "amount": parse_dollar_amount(row["amount"]),
+                }
+            )
+    return rows
+
+
+def settlement_row(order_id: str, charge: dict, txn: dict, status: str) -> dict:
+    delta = charge["charged"] - txn["amount"]
+    return {
+        "order_id": order_id,
+        "txn_id": txn["txn_id"],
+        "status": status,
+        "internal_cents": charge["charged"].to_cents(),
+        "bank_cents": txn["amount"].to_cents(),
+        "delta_cents": delta.to_cents(),
+    }
+
+
+def reconcile_charge(order_id: str, charge: dict, candidates: list[dict]) -> list[dict]:
+    """All reconciliation rows for one in-range charge."""
+    if not candidates:
+        return [
+            {
+                "order_id": order_id,
+                "txn_id": "",
+                "status": "missing_bank",
+                "internal_cents": charge["charged"].to_cents(),
+                "bank_cents": "",
+                "delta_cents": "",
+            }
+        ]
+    window_start = charge["charged_at"]
+    window_end = window_start + timedelta(days=SETTLEMENT_WINDOW_DAYS)
+
+    def preference(txn: dict) -> tuple:
+        amount_matches = txn["amount"] == charge["charged"]
+        in_window = window_start <= txn["settled_on"] <= window_end
+        rank = 0 if amount_matches and in_window else 1 if amount_matches else 2 if in_window else 3
+        return (rank, txn["settled_on"], txn["txn_id"])
+
+    settlement = min(candidates, key=preference)
+    if settlement["amount"] == charge["charged"]:
+        in_window = window_start <= settlement["settled_on"] <= window_end
+        status = "matched" if in_window else "late_settlement"
+    else:
+        status = "amount_mismatch"
+    rows = [settlement_row(order_id, charge, settlement, status)]
+    for txn in candidates:
+        if txn is not settlement:
+            rows.append(settlement_row(order_id, charge, txn, "duplicate"))
+    return rows
+
+
+def run(from_month: str, to_month: str, out_dir: Path = DEFAULT_OUT_DIR) -> None:
+    months = month_range(from_month, to_month)
+    charges = load_recorded_charges()
+
+    candidates_by_order: dict[str, list[dict]] = {}
+    unknown_ref_rows = []
+    for txn in load_bank_rows():
+        order_id = order_id_for_ref(txn["bank_ref"])
+        if order_id is not None and order_id in charges:
+            # Reported in the month of the charge; dropped entirely if the
+            # charge falls outside the requested range.
+            candidates_by_order.setdefault(order_id, []).append(txn)
+        else:
+            unknown_ref_rows.append(txn)
+
+    rows_by_month: dict[str, list[dict]] = {m: [] for m in months}
+    for order_id, charge in charges.items():
+        month = charge["charged_at"].isoformat()[:7]
+        if month not in rows_by_month:
+            continue
+        rows_by_month[month].extend(
+            reconcile_charge(order_id, charge, candidates_by_order.get(order_id, []))
+        )
+    for txn in unknown_ref_rows:
+        month = txn["settled_on"].isoformat()[:7]
+        if month not in rows_by_month:
+            continue
+        rows_by_month[month].append(
+            {
+                "order_id": "",
+                "txn_id": txn["txn_id"],
+                "status": "unknown_ref",
+                "internal_cents": "",
+                "bank_cents": txn["amount"].to_cents(),
+                "delta_cents": "",
+            }
+        )
+
+    out_dir.mkdir(parents=True, exist_ok=True)
+    fieldnames = ["order_id", "txn_id", "status", "internal_cents", "bank_cents", "delta_cents"]
+    summary: dict[str, dict] = {}
+    for month in months:
+        rows = sorted(
+            rows_by_month[month],
+            key=lambda r: (r["order_id"] == "", r["order_id"], r["txn_id"]),
+        )
+        with (out_dir / f"{month}.csv").open("w", newline="") as f:
+            writer = csv.DictWriter(f, fieldnames=fieldnames)
+            writer.writeheader()
+            writer.writerows(rows)
+        counts = {status: 0 for status in STATUSES}
+        net_delta = Money(0)
+        for row in rows:
+            counts[row["status"]] += 1
+            if row["delta_cents"] != "":
+                net_delta = net_delta + Money.from_cents(row["delta_cents"])
+        summary[month] = {**counts, "net_delta_cents": net_delta.to_cents()}
+
+    (out_dir / "summary.json").write_text(
+        json.dumps({"months": summary}, indent=2, sort_keys=True) + "\n"
+    )
+
+
+def main(argv: list[str] | None = None) -> int:
+    parser = argparse.ArgumentParser(description=__doc__)
+    parser.add_argument("--from", dest="from_month", type=parse_month, required=True)
+    parser.add_argument("--to", dest="to_month", type=parse_month, required=True)
+    args = parser.parse_args(argv)
+    try:
+        run(args.from_month, args.to_month)
+    except ValueError as exc:
+        parser.error(str(exc))
+    return 0
+
+
+if __name__ == "__main__":
+    sys.exit(main())
