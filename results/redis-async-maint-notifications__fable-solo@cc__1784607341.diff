+"""
+Hermetic wire-level tests for maintenance notifications on the async
+standalone client (`redis.asyncio.Redis`).
+
+These mirror the sync suites in ``test_maint_notifications_handling.py``:
+no live server is used - ``asyncio.open_connection`` is patched to return a
+scripted (reader, writer) pair that speaks just enough RESP3 and injects
+maintenance push messages before selected command responses.
+"""
+
+import asyncio
+from typing import List, Union
+from unittest.mock import patch
+
+import pytest
+
+from redis._defaults import DEFAULT_SOCKET_CONNECT_TIMEOUT, DEFAULT_SOCKET_TIMEOUT
+from redis.asyncio import Redis
+from redis.asyncio.connection import (
+    AbstractConnection,
+    BlockingConnectionPool,
+    Connection,
+    ConnectionPool,
+)
+from redis.exceptions import ResponseError
+from redis.maint_notifications import (
+    EndpointType,
+    MaintenanceState,
+    MaintNotificationsConfig,
+    NodeFailedOverNotification,
+    NodeFailingOverNotification,
+    NodeMigratedNotification,
+    NodeMigratingNotification,
+    NodeMovingNotification,
+)
+
+AFTER_MOVING_ADDRESS = "1.2.3.4:6379"
+DEFAULT_ADDRESS = "12.45.34.56:6379"
+MOVING_TIMEOUT = 1
+
+MOVING_NOTIFICATION = NodeMovingNotification(
+    id=1,
+    new_node_host=AFTER_MOVING_ADDRESS.split(":")[0],
+    new_node_port=int(AFTER_MOVING_ADDRESS.split(":")[1]),
+    ttl=MOVING_TIMEOUT,
+)
+
+MOVING_NONE_NOTIFICATION = NodeMovingNotification(
+    id=1,
+    new_node_host=None,
+    new_node_port=None,
+    ttl=MOVING_TIMEOUT,
+)
+
+
+class MockRawSocket:
+    """Raw-socket stand-in exposed via writer.transport.get_extra_info."""
+
+    def __init__(self, backend):
+        self.backend = backend
+        self.timeout = None
+
+    def setsockopt(self, level, optname, value):
+        pass
+
+    def getpeername(self):
+        return (self.backend.host, self.backend.port)
+
+    def getsockname(self):
+        return (self.backend.host, 12345)
+
+    def gettimeout(self):
+        return self.timeout
+
+    def settimeout(self, timeout):
+        self.timeout = timeout
+
+    def fileno(self):
+        return 1
+
+
+class MockTransport:
+    def __init__(self, backend):
+        self.backend = backend
+
+    def get_extra_info(self, name, default=None):
+        if name == "socket":
+            return self.backend.raw_socket
+        return default
+
+
+class MockWriter:
+    def __init__(self, backend):
+        self.backend = backend
+        self.transport = MockTransport(backend)
+
+    def write(self, data):
+        self.backend.feed_command(bytes(data))
+
+    def writelines(self, data):
+        self.backend.feed_command(b"".join(data))
+
+    async def drain(self):
+        pass
+
+    def close(self):
+        if not self.backend.closed:
+            self.backend.closed = True
+            self.backend.connected = False
+            try:
+                self.backend.reader.feed_eof()
+            except Exception:
+                pass
+
+    async def wait_closed(self):
+        pass
+
+    def is_closing(self):
+        return self.backend.closed
+
+
+class MockConnectionBackend:
+    """
+    One scripted server-side per established connection.
+
+    Bytes written by the client are analyzed and the scripted RESP response
+    (optionally prefixed by a maintenance push message) is fed straight into
+    the connection's StreamReader.
+    """
+
+    def __init__(self, host, port):
+        self.host = host
+        self.port = int(port)
+        self.reader = asyncio.StreamReader()
+        self.raw_socket = MockRawSocket(self)
+        self.writer = MockWriter(self)
+        self.connected = True
+        self.closed = False
+        self.sent_data: List[bytes] = []
+
+    def feed_command(self, data: bytes):
+        if self.closed:
+            raise ConnectionError("Socket is closed")
+        self.sent_data.append(data)
+
+        if b"HELLO" in data:
+            response = (
+                b"%7\r\n$6\r\nserver\r\n$5\r\nredis\r\n$7\r\nversion\r\n$5\r\n7.4.0\r\n"
+                b"$5\r\nproto\r\n:3\r\n$2\r\nid\r\n:1\r\n$4\r\nmode\r\n$10\r\nstandalone\r\n"
+                b"$4\r\nrole\r\n$6\r\nmaster\r\n$7\r\nmodules\r\n*0\r\n"
+            )
+        elif b"MAINT_NOTIFICATIONS" in data and b"internal-ip" in data:
+            # Simulate a server without maintenance notifications support -
+            # activated only for internal-ip tests
+            response = b"+ERROR\r\n"
+        elif b"SET" in data:
+            response = b"+OK\r\n"
+
+            if b"key_receive_migrating" in data:
+                migrating_push = b">3\r\n$9\r\nMIGRATING\r\n:1\r\n:10\r\n"
+                response = migrating_push + response
+            elif b"key_receive_migrated" in data:
+                migrated_push = b">2\r\n$8\r\nMIGRATED\r\n:1\r\n"
+                response = migrated_push + response
+            elif b"key_receive_failing_over" in data:
+                failing_over_push = b">3\r\n$12\r\nFAILING_OVER\r\n:1\r\n:10\r\n"
+                response = failing_over_push + response
+            elif b"key_receive_failed_over" in data:
+                failed_over_push = b">2\r\n$11\r\nFAILED_OVER\r\n:1\r\n"
+                response = failed_over_push + response
+            elif b"key_receive_moving_none_" in data:
+                moving_push = (
+                    f">4\r\n$6\r\nMOVING\r\n:1\r\n:{MOVING_TIMEOUT}\r\n_\r\n".encode()
+                )
+                response = moving_push + response
+            elif b"key_receive_moving_" in data:
+                moving_push = (
+                    f">4\r\n$6\r\nMOVING\r\n:1\r\n:{MOVING_TIMEOUT}\r\n"
+                    f"+{AFTER_MOVING_ADDRESS}\r\n".encode()
+                )
+                response = moving_push + response
+        elif b"GET" in data:
+            if b"hello" in data:
+                response = b"$5\r\nworld\r\n"
+            elif b"key_receive_moving_0" in data:
+                response = b"$8\r\nvalue3_0\r\n"
+            elif b"key_receive_migrating" in data:
+                response = b"$6\r\nvalue2\r\n"
+            elif b"key_receive_migrated" in data:
+                response = b"$6\r\nvalue3\r\n"
+            elif b"key_receive_failing_over" in data:
+                response = b"$6\r\nvalue4\r\n"
+            elif b"key_receive_failed_over" in data:
+                response = b"$6\r\nvalue5\r\n"
+            elif b"key1" in data:
+                response = b"$6\r\nvalue1\r\n"
+            else:
+                response = b"$-1\r\n"
+        else:
+            response = b"+OK\r\n"
+
+        self.reader.feed_data(response)
+
