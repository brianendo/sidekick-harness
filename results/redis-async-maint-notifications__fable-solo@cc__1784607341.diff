+class Helpers:
+    """Validation helpers mirroring the sync suite's Helpers class."""
+
+    @staticmethod
+    def validate_in_use_connections_state(
+        in_use_connections: List[AbstractConnection],
+        expected_state=MaintenanceState.NONE,
+        expected_should_reconnect: Union[bool, str] = True,
+        expected_host_address=DEFAULT_ADDRESS.split(":")[0],
+        expected_socket_timeout=DEFAULT_SOCKET_TIMEOUT,
+        expected_socket_connect_timeout=DEFAULT_SOCKET_CONNECT_TIMEOUT,
+        expected_orig_host_address=DEFAULT_ADDRESS.split(":")[0],
+        expected_orig_socket_timeout=DEFAULT_SOCKET_TIMEOUT,
+        expected_orig_socket_connect_timeout=DEFAULT_SOCKET_CONNECT_TIMEOUT,
+        expected_current_peername=DEFAULT_ADDRESS.split(":")[0],
+    ):
+        for connection in in_use_connections:
+            if expected_should_reconnect != "any":
+                assert connection.should_reconnect() == expected_should_reconnect
+            assert connection.host == expected_host_address
+            assert connection.socket_timeout == expected_socket_timeout
+            assert connection.socket_connect_timeout == expected_socket_connect_timeout
+            assert connection.orig_host_address == expected_orig_host_address
+            assert connection.orig_socket_timeout == expected_orig_socket_timeout
+            assert (
+                connection.orig_socket_connect_timeout
+                == expected_orig_socket_connect_timeout
+            )
+            conn_socket = connection._get_socket()
+            if conn_socket is not None:
+                assert conn_socket.backend.connected is True
+                if expected_current_peername != "any":
+                    assert conn_socket.getpeername()[0] == expected_current_peername
+            assert connection.maintenance_state == expected_state
+
+    @staticmethod
+    def validate_free_connections_state(
+        pool,
+        should_be_connected_count=0,
+        connected_to_tmp_address=False,
+        tmp_address=AFTER_MOVING_ADDRESS.split(":")[0],
+        expected_state=MaintenanceState.MOVING,
+        expected_host_address=DEFAULT_ADDRESS.split(":")[0],
+        expected_socket_timeout=DEFAULT_SOCKET_TIMEOUT,
+        expected_socket_connect_timeout=DEFAULT_SOCKET_CONNECT_TIMEOUT,
+        expected_orig_host_address=DEFAULT_ADDRESS.split(":")[0],
+        expected_orig_socket_timeout=DEFAULT_SOCKET_TIMEOUT,
+        expected_orig_socket_connect_timeout=DEFAULT_SOCKET_CONNECT_TIMEOUT,
+    ):
+        free_connections = pool._available_connections
+
+        connected_count = 0
+        for connection in free_connections:
+            assert connection.should_reconnect() is False
+            assert connection.host == expected_host_address
+            assert connection.socket_timeout == expected_socket_timeout
+            assert connection.socket_connect_timeout == expected_socket_connect_timeout
+            assert connection.orig_host_address == expected_orig_host_address
+            assert connection.orig_socket_timeout == expected_orig_socket_timeout
+            assert (
+                connection.orig_socket_connect_timeout
+                == expected_orig_socket_connect_timeout
+            )
+            assert connection.maintenance_state == expected_state
+            if expected_state == MaintenanceState.NONE:
+                assert connection.maintenance_notification_hash is None
+
+            conn_socket = connection._get_socket()
+            if conn_socket is not None and conn_socket.backend.connected:
+                if connected_to_tmp_address and tmp_address != "any":
+                    assert conn_socket.getpeername()[0] == tmp_address
+                connected_count += 1
+        assert connected_count == should_be_connected_count
+
+    @staticmethod
+    def validate_conn_kwargs(
+        pool,
+        expected_maintenance_state,
+        expected_maintenance_notification_hash,
+        expected_host_address,
+        expected_port,
+        expected_socket_timeout,
+        expected_socket_connect_timeout,
+        expected_orig_host_address,
+        expected_orig_socket_timeout,
+        expected_orig_socket_connect_timeout,
+    ):
+        assert pool.connection_kwargs["maintenance_state"] == expected_maintenance_state
+        assert (
+            pool.connection_kwargs["maintenance_notification_hash"]
+            == expected_maintenance_notification_hash
+        )
+        assert pool.connection_kwargs["host"] == expected_host_address
+        assert pool.connection_kwargs["port"] == expected_port
+        assert pool.connection_kwargs["socket_timeout"] == expected_socket_timeout
+        assert (
+            pool.connection_kwargs["socket_connect_timeout"]
+            == expected_socket_connect_timeout
+        )
+        assert (
+            pool.connection_kwargs.get("orig_host_address", None)
+            == expected_orig_host_address
+        )
+        assert (
+            pool.connection_kwargs.get("orig_socket_timeout", None)
+            == expected_orig_socket_timeout
+        )
+        assert (
+            pool.connection_kwargs.get("orig_socket_connect_timeout", None)
+            == expected_orig_socket_connect_timeout
+        )
+
+
+class TestAsyncMaintenanceNotificationsBase:
+    """Base class for the async maintenance notifications handling tests."""
+
+    def setup_method(self):
+        self.mock_backends: List[MockConnectionBackend] = []
+
+        async def mock_open_connection(host=None, port=None, **kwargs):
+            backend = MockConnectionBackend(host, port)
+            self.mock_backends.append(backend)
+            return backend.reader, backend.writer
+
+        self.open_connection_patcher = patch(
+            "asyncio.open_connection", side_effect=mock_open_connection
+        )
+        self.open_connection_patcher.start()
+
+        self.config = MaintNotificationsConfig(
+            enabled=True, proactive_reconnect=True, relaxed_timeout=30
+        )
+
+    def teardown_method(self):
+        self.open_connection_patcher.stop()
+
+    def _get_client(
+        self,
+        pool_class,
+        connection_class=Connection,
+        max_connections=10,
+        maint_notifications_config=None,
+        protocol=3,
+    ):
+        config = (
+            maint_notifications_config
+            if maint_notifications_config is not None
+            else self.config
+        )
+        pool_kwargs = {}
+        if config is not SENTINEL_NO_CONFIG:
+            pool_kwargs["maint_notifications_config"] = config
+
+        test_pool = pool_class(
+            connection_class=connection_class,
+            host=DEFAULT_ADDRESS.split(":")[0],
+            port=int(DEFAULT_ADDRESS.split(":")[1]),
+            max_connections=max_connections,
+            protocol=protocol,
+            **pool_kwargs,
+        )
+        return Redis(connection_pool=test_pool)
+
+    def _validate_disconnected(self, expected_count):
+        disconnected = sum(1 for backend in self.mock_backends if backend.closed)
+        assert disconnected == expected_count
+
+    def _validate_connected(self, expected_count):
+        connected = sum(1 for backend in self.mock_backends if backend.connected)
+        assert connected == expected_count
+
+    def _all_sent_data(self) -> bytes:
+        return b"".join(
+            data for backend in self.mock_backends for data in backend.sent_data
+        )
+
+
+# Sentinel used by _get_client to create a pool WITHOUT passing any
+# maint_notifications_config kwarg (to exercise the auto-enable default).
+SENTINEL_NO_CONFIG = object()
+
+
+@pytest.mark.fixed_client
+class TestAsyncMaintenanceNotificationsHandshake(TestAsyncMaintenanceNotificationsBase):
+    """Handshake behavior of the async standalone client."""
+
+    async def test_handshake_success_when_enabled(self):
+        maint_notifications_config = MaintNotificationsConfig(
+            enabled=True, endpoint_type=EndpointType.EXTERNAL_IP
+        )
+        client = self._get_client(
+            ConnectionPool, maint_notifications_config=maint_notifications_config
+        )
+        try:
+            assert await client.set("hello", "world") is True
+            assert await client.get("hello") == b"world"
+
+            sent = self._all_sent_data()
+            assert b"MAINT_NOTIFICATIONS" in sent
+            assert b"moving-endpoint-type" in sent
+            assert b"external-ip" in sent
+        finally:
+            await client.connection_pool.disconnect()
+
+    async def test_handshake_success_when_auto_and_command_not_supported(self):
+        maint_notifications_config = MaintNotificationsConfig(
+            enabled="auto", endpoint_type=EndpointType.INTERNAL_IP
+        )
+        client = self._get_client(
+            ConnectionPool, maint_notifications_config=maint_notifications_config
+        )
+        try:
+            # the mocked server rejects the MAINT_NOTIFICATIONS command for
+            # internal-ip, but with "auto" the client continues to work
+            assert await client.set("hello", "world") is True
+            assert await client.get("hello") == b"world"
+        finally:
+            await client.connection_pool.disconnect()
+
+    async def test_handshake_failure_when_enabled(self):
+        maint_notifications_config = MaintNotificationsConfig(
+            enabled=True, endpoint_type=EndpointType.INTERNAL_IP
+        )
+        client = self._get_client(
+            ConnectionPool, maint_notifications_config=maint_notifications_config
+        )
+        try:
+            with pytest.raises(ResponseError):
+                # handshake should fail - the mocked server returns an error
+                # when enabling maint notifications for internal-ip
+                await client.set("hello", "world")
+        finally:
+            await client.connection_pool.disconnect()
+
+    async def test_handshake_sent_by_default_on_resp3(self):
+        """RESP3 with no explicit config auto-enables maintenance notifications."""
+        client = self._get_client(
+            ConnectionPool, maint_notifications_config=SENTINEL_NO_CONFIG
+        )
+        try:
+            # the default config uses enabled="auto"
+            assert client.connection_pool.maint_notifications_enabled() == "auto"
+            assert await client.set("hello", "world") is True
+            assert b"MAINT_NOTIFICATIONS" in self._all_sent_data()
+        finally:
+            await client.connection_pool.disconnect()
+
+    async def test_no_handshake_on_resp2(self):
+        """RESP2 connections must be completely untouched."""
+        client = self._get_client(
+            ConnectionPool, maint_notifications_config=SENTINEL_NO_CONFIG, protocol=2
+        )
+        try:
+            assert not client.connection_pool.maint_notifications_enabled()
+            assert client.connection_pool._maint_notifications_pool_handler is None
+
+            assert await client.set("hello", "world") is True
+            assert await client.get("hello") == b"world"
+
+            assert b"MAINT_NOTIFICATIONS" not in self._all_sent_data()
+
+            conn = await client.connection_pool.get_connection()
+            try:
+                assert conn._maint_notifications_connection_handler is None
+                assert conn._maint_notifications_pool_handler is None
+                # the RESP2 parser has no maintenance push handler hooks at all
+                assert (
+                    getattr(conn._parser, "node_moving_push_handler_func", None) is None
+                )
+                assert (
+                    getattr(conn._parser, "maintenance_push_handler_func", None) is None
+                )
+            finally:
+                await client.connection_pool.release(conn)
+        finally:
+            await client.connection_pool.disconnect()
+
+    async def test_no_handshake_when_disabled(self):
+        """A disabled config means a completely untouched connection lifecycle."""
+        disabled_config = MaintNotificationsConfig(enabled=False)
+        client = self._get_client(
+            ConnectionPool, maint_notifications_config=disabled_config
+        )
+        try:
+            assert not client.connection_pool.maint_notifications_enabled()
+
+            assert await client.set("hello", "world") is True
+            assert await client.get("hello") == b"world"
+
+            assert b"MAINT_NOTIFICATIONS" not in self._all_sent_data()
+            # connection kwargs must not be touched by maintenance logic
+            assert "orig_host_address" not in client.connection_pool.connection_kwargs
+            assert (
+                "maint_notifications_pool_handler"
+                not in client.connection_pool.connection_kwargs
+            )
+
+            conn = await client.connection_pool.get_connection()
+            try:
+                assert conn._maint_notifications_connection_handler is None
+                assert conn._parser.node_moving_push_handler_func is None
+                assert conn._parser.maintenance_push_handler_func is None
+            finally:
+                await client.connection_pool.release(conn)
+        finally:
+            await client.connection_pool.disconnect()
+
