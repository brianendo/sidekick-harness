+        Test that start() accepts a synchronous callable that calls
+        task_status.started() before returning the coroutine to run as the task.
+        """
+
+        async def taskfunc() -> str:
+            return "return value"
+
+        def wrapper(*, task_status: TaskStatus[str]) -> Coroutine[Any, Any, str]:
+            task_status.started("started value")
+            return taskfunc()
+
+        async with create_task_group() as tg:
+            assert await tg.start(wrapper) == "started value"
+
+            handle = await tg.start(wrapper, return_handle=True)
+            assert handle.start_value == "started value"
+            assert await handle == "return value"
+
+    async def test_sync_callable_started_from_coroutine(self) -> None:
