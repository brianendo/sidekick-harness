+"""Tests for the first-class geopandas API: ``pandera.geopandas``."""
+
+from typing import Annotated
+
+import geopandas as gpd
+import pandas as pd
+import pytest
+from pydantic import BaseModel, ValidationError
+from shapely.geometry import Point, Polygon
+
+import pandera.geopandas as pa
+import pandera.pandas as papd
+from pandera.api.geopandas.container import GeoDataFrameSchema
+from pandera.api.geopandas.model import GeoDataFrameModel
+from pandera.errors import SchemaError, SchemaErrors
+
+
+@pytest.fixture
+def gdf() -> gpd.GeoDataFrame:
+    return gpd.GeoDataFrame(
+        {
+            "geometry": gpd.GeoSeries(
+                [Point(0, 0), Point(1, 1)], crs="EPSG:4326"
+            ),
+            "name": ["a", "b"],
+        }
+    )
+
+
+@pytest.fixture
+def schema() -> pa.GeoDataFrameSchema:
+    return pa.GeoDataFrameSchema(
+        {
+            "geometry": pa.Column("geometry"),
+            "name": pa.Column(str),
+        }
+    )
+
+
+class Model(pa.GeoDataFrameModel):
+    """Class-based equivalent of the ``schema`` fixture."""
+
+    geometry: pa.GeoSeries
+    name: str = pa.Field(isin=["a", "b"])
+
+
+def test_module_exports():
+    """The geopandas entrypoint exposes the pandas-equivalent surface."""
+    from pandera.geopandas import (  # pylint: disable=unused-import
+        Check,
+        Column,
+        Field,
+        Geometry,
+        infer_schema,
+    )
+    from pandera.geopandas import (
+        GeoDataFrameModel as _GeoDataFrameModel,
+    )
+    from pandera.geopandas import (
+        GeoDataFrameSchema as _GeoDataFrameSchema,
+    )
+
+    assert _GeoDataFrameSchema is GeoDataFrameSchema
+    assert _GeoDataFrameModel is GeoDataFrameModel
+
+
+def test_schema_validate_returns_geodataframe(gdf, schema):
+    """validate() returns a GeoDataFrame with geometry and CRS intact."""
+    validated = schema.validate(gdf)
+    assert isinstance(validated, gpd.GeoDataFrame)
+    assert validated.geometry.name == "geometry"
+    assert validated.crs == "EPSG:4326"
+    # __call__ alias behaves the same
+    assert isinstance(schema(gdf), gpd.GeoDataFrame)
+
+
+def test_schema_validate_restores_geodataframe_from_pandas():
+    """Validating a plain DataFrame with coercible geometry returns a
+    GeoDataFrame with active geometry and schema-designated CRS — where
+    the plain-pandas schema returns a plain DataFrame."""
+    df = pd.DataFrame(
+        {
+            "geometry": ["POINT (0 0)", "POINT (1 1)"],
+            "name": ["a", "b"],
+        }
+    )
+
+    geo_schema = pa.GeoDataFrameSchema(
+        {
+            "geometry": pa.Column(pa.Geometry(crs="EPSG:4326"), coerce=True),
+            "name": pa.Column(str),
+        }
+    )
+    validated = geo_schema.validate(df)
+    assert isinstance(validated, gpd.GeoDataFrame)
+    assert validated.geometry.name == "geometry"
+    assert validated.crs == "EPSG:4326"
+
+    # the pandas equivalent loses the GeoDataFrame type on the way out
+    pandas_schema = papd.DataFrameSchema(
+        {
+            "geometry": papd.Column(pa.Geometry(crs="EPSG:4326"), coerce=True),
+            "name": papd.Column(str),
+        }
+    )
+    pandas_validated = pandas_schema.validate(df)
+    assert not isinstance(pandas_validated, gpd.GeoDataFrame)
+
+
+def test_schema_validate_activates_nonstandard_geometry_column():
+    """A single geometry column with a non-standard name becomes the
+    active geometry."""
+    df = pd.DataFrame({"geom": gpd.GeoSeries([Point(0, 0)], crs="EPSG:3857")})
+    geo_schema = pa.GeoDataFrameSchema({"geom": pa.Column("geometry")})
+    validated = geo_schema.validate(df)
+    assert isinstance(validated, gpd.GeoDataFrame)
+    assert validated.geometry.name == "geom"
+    assert validated.crs == "EPSG:3857"
+
+
+def test_schema_validate_raises_schema_errors(gdf, schema):
+    """Validation failures raise pandera's usual errors."""
+    bad_schema = pa.GeoDataFrameSchema(
+        {
+            "geometry": pa.Column("geometry"),
+            "name": pa.Column(str, pa.Check.isin(["z"])),
+        }
+    )
+    with pytest.raises(SchemaError):
+        bad_schema.validate(gdf)
+
+    with pytest.raises(SchemaErrors):
+        bad_schema.validate(gdf, lazy=True)
+
+    # passing schema still works after failure
+    assert isinstance(schema.validate(gdf), gpd.GeoDataFrame)
+
+
+def test_schema_checks_and_dtype_coercion(gdf):
+    """Column checks and geometry-aware coercion work as in pandas."""
+    geo_schema = pa.GeoDataFrameSchema(
+        {
+            "geometry": pa.Column(
+                pa.Geometry(crs="EPSG:4326"),
+                pa.Check(lambda s: ~s.is_empty),
+                coerce=True,
+            ),
+            "name": pa.Column(str),
+        },
+        strict=True,
+    )
+    validated = geo_schema.validate(gdf)
+    assert isinstance(validated, gpd.GeoDataFrame)
+    assert validated.crs == "EPSG:4326"
+
+    failing = gdf.copy()
+    failing["geometry"] = gpd.GeoSeries(
+        [Point(0, 0), Polygon()], crs="EPSG:4326"
+    )
+    with pytest.raises(SchemaError):
+        geo_schema.validate(failing)
+
+
+def test_model_validate_returns_geodataframe(gdf):
+    """The class-based API returns a GeoDataFrame with CRS intact."""
+    validated = Model.validate(gdf)
+    assert isinstance(validated, gpd.GeoDataFrame)
+    assert validated.geometry.name == "geometry"
+    assert validated.crs == "EPSG:4326"
+
+
+def test_model_to_schema_is_geo_schema():
+    """GeoDataFrameModel produces a GeoDataFrameSchema."""
+    assert isinstance(Model.to_schema(), GeoDataFrameSchema)
+
+
+def test_model_field_and_checks(gdf):
+    """Field constraints and custom checks work on geo models."""
+
+    class CheckedModel(pa.GeoDataFrameModel):
+        geometry: pa.GeoSeries
+        name: str = pa.Field(isin=["a", "b"])
+
+        @pa.check("geometry")
+        @classmethod
+        def not_empty(cls, geo_series):
+            return ~geo_series.is_empty
+
+    assert isinstance(CheckedModel.validate(gdf), gpd.GeoDataFrame)
+
+    bad = gdf.copy()
+    bad["name"] = ["z", "z"]
+    with pytest.raises(SchemaError):
+        CheckedModel.validate(bad)
+
+
+def test_model_config_coercion():
+    """Class config drives coercion, mirroring pandas ergonomics."""
+
+    class CoercingModel(pa.GeoDataFrameModel):
+        geometry: Annotated[pa.Geometry, "EPSG:4326"]
+        name: str
+
+        class Config:
+            coerce = True
+
+    df = pd.DataFrame(
+        {"geometry": ["POINT (0 0)", "POINT (1 1)"], "name": ["a", "b"]}
+    )
+    validated = CoercingModel.validate(df)
+    assert isinstance(validated, gpd.GeoDataFrame)
+    assert validated.crs == "EPSG:4326"
+
+
+def test_check_types_decorator(gdf):
+    """@check_types validates geo-typed inputs and outputs."""
+
+    @pa.check_types
+    def transform(
+        data: pa.GeoDataFrame[Model],
+    ) -> pa.GeoDataFrame[Model]:
+        return data
+
+    result = transform(gdf)
+    assert isinstance(result, gpd.GeoDataFrame)
+
+    with pytest.raises(SchemaError):
+        transform(gdf.assign(name=["y", "z"]))
+
+
+def test_schema_json_roundtrip(gdf, schema):
+    """A schema serialized to JSON and loaded back still validates a
+    GeoDataFrame and still returns a GeoDataFrame."""
+    serialized = schema.to_json()
+    loaded = pa.GeoDataFrameSchema.from_json(serialized)
+
+    assert isinstance(loaded, GeoDataFrameSchema)
+    validated = loaded.validate(gdf)
+    assert isinstance(validated, gpd.GeoDataFrame)
+    assert validated.crs == "EPSG:4326"
+
+
+def test_schema_json_roundtrip_via_io_module(gdf, schema):
+    """The generic io entrypoint reconstructs the geopandas schema class."""
+    from pandera.io import pandas_io
+
+    loaded = pandas_io.from_json(schema.to_json())
+    assert isinstance(loaded, GeoDataFrameSchema)
+    assert isinstance(loaded.validate(gdf), gpd.GeoDataFrame)
+
+
+def test_schema_yaml_roundtrip(gdf, schema):
+    """YAML serialization also round-trips to a geopandas schema."""
+    pytest.importorskip("yaml")
+    loaded = pa.GeoDataFrameSchema.from_yaml(schema.to_yaml())
+    assert isinstance(loaded, GeoDataFrameSchema)
+    assert isinstance(loaded.validate(gdf), gpd.GeoDataFrame)
+
+
+def test_model_json_roundtrip(gdf):
+    """Model-level to_json/from_json round-trips to a geopandas schema."""
+    loaded = Model.from_json(Model.to_json())
+    assert isinstance(loaded, GeoDataFrameSchema)
+    assert isinstance(loaded.validate(gdf), gpd.GeoDataFrame)
+
+
+def test_infer_schema(gdf):
+    """infer_schema on a GeoDataFrame produces a geopandas schema that
+    validates it and preserves CRS metadata."""
+    inferred = pa.infer_schema(gdf)
+    assert isinstance(inferred, GeoDataFrameSchema)
+
+    validated = inferred.validate(gdf)
+    assert isinstance(validated, gpd.GeoDataFrame)
+    assert validated.crs == "EPSG:4326"
+
+    # the geometry column dtype captures the CRS of the data
+    geometry_dtype = inferred.columns["geometry"].dtype
+    assert isinstance(geometry_dtype, pa.Geometry)
+    assert geometry_dtype.crs == "EPSG:4326"
+
+
+def test_infer_schema_geoseries():
+    """infer_schema also accepts a GeoSeries."""
+    series_schema = pa.infer_schema(gpd.GeoSeries([Point(0, 0)]))
+    assert isinstance(
+        series_schema.validate(gpd.GeoSeries([Point(0, 0)])), pd.Series
+    )
+
+
+def test_infer_schema_invalid_type():
+    with pytest.raises(TypeError):
+        pa.infer_schema([Point(0, 0)])
+
+
+def test_geo_model_as_pydantic_field(gdf):
+    """A geo model works as a pydantic model field: valid frames are
+    accepted (returned as GeoDataFrames), invalid ones raise pydantic's
+    ValidationError."""
+
+    class PydanticModel(BaseModel):
+        data: pa.GeoDataFrame[Model]
+
+    valid = PydanticModel(data=gdf)
+    assert isinstance(valid.data, gpd.GeoDataFrame)
+    assert valid.data.crs == "EPSG:4326"
+
+    with pytest.raises(ValidationError):
+        PydanticModel(data=gdf.assign(name=["y", "z"]))
+
+    with pytest.raises(ValidationError):
+        PydanticModel(data="not a dataframe")
+
+
+def test_plain_pandas_schema_unchanged():
+    """Plain-pandas users see no change: pandas schemas still return
+    plain DataFrames for plain inputs."""
+    pandas_schema = papd.DataFrameSchema({"x": papd.Column(int)})
+    out = pandas_schema.validate(pd.DataFrame({"x": [1, 2]}))
+    assert type(out) is pd.DataFrame
+
+    serialized = pandas_schema.to_json()
+    loaded = papd.DataFrameSchema.from_json(serialized)
+    assert type(loaded) is papd.DataFrameSchema
