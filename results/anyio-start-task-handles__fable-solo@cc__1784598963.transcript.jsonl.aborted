{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01QFHH2P7175ZEpsSzrwGVBj","type":"tool_result","content":"1474\tasync def test_start_soon_parent_id() -> None:\n1475\t    root_task_id = get_current_task().id\n1476\t    parent_id: int | None = None\n1477\t\n1478\t    async def subtask() -> None:\n1479\t        nonlocal parent_id\n1480\t        parent_id = get_current_task().parent_id\n1481\t\n1482\t    async def starter_task() -> None:\n1483\t        tg.start_soon(subtask)\n1484\t\n1485\t    async with anyio.create_task_group() as tg:\n1486\t        tg.start_soon(starter_task)\n1487\t\n1488\t    assert parent_id == root_task_id\n1489\t\n1490\t\n1491\tasync def test_start_parent_id() -> None:\n1492\t    root_task_id = get_current_task().id\n1493\t    starter_task_id: int | None = None\n1494\t    initial_parent_id: int | None = None\n1495\t    permanent_parent_id: int | None = None\n1496\t\n1497\t    async def subtask(*, task_status: TaskStatus) -> None:\n1498\t        nonlocal initial_parent_id, permanent_parent_id\n1499\t        initial_parent_id = get_current_task().parent_id\n1500\t        task_status.started()\n1501\t        permanent_parent_id = get_current_task().parent_id\n1502\t\n1503\t    async def starter_task() -> None:\n1504\t        nonlocal starter_task_id\n1505\t        starter_task_id = get_current_task().id\n1506\t        await tg.start(subtask)\n1507\t\n1508\t    async with anyio.create_task_group() as tg:\n1509\t        tg.start_soon(starter_task)\n1510\t\n1511\t    assert initial_parent_id != permanent_parent_id\n1512\t    assert initial_parent_id == starter_task_id\n1513\t    assert permanent_parent_id == root_task_id\n1514\t\n1515\t\n1516\t@pytest.mark.skipif(\n1517\t    sys.version_info < (3, 11),\n1518\t    reason=\"Task uncancelling is only supported on Python 3.11\",\n1519\t)\n1520\t@pytest.mark.parametrize(\"anyio_backend\", asyncio_params)\n1521\tclass TestUncancel:\n1522\t    async def test_uncancel_after_native_cancel(self) -> None:\n1523\t        task = cast(asyncio.Task, asyncio.current_task())\n1524\t        with pytest.raises(asyncio.CancelledError), CancelScope():\n1525\t            task.cancel()\n1526\t            await checkpoint()\n1527\t\n1528\t        assert task.cancelling() == 1\n1529\t        task.uncancel()\n1530\t\n1531\t    async def test_uncancel_after_scope_cancel(self) -> None:\n1532\t        task = cast(asyncio.Task, asyncio.current_task())\n1533\t        with CancelScope() as scope:\n1534\t            scope.cancel()\n1535\t            await checkpoint()\n1536\t\n1537\t        assert task.cancelling() == 0\n1538\t\n1539\t    async def test_uncancel_after_scope_and_native_cancel(self) -> None:\n1540\t        task = cast(asyncio.Task, asyncio.current_task())\n1541\t        with pytest.raises(asyncio.CancelledError), CancelScope() as scope:\n1542\t            scope.cancel()\n1543\t            task.cancel()\n1544\t            await checkpoint()\n1545\t\n1546\t        assert task.cancelling() == 1\n1547\t        task.uncancel()\n1548\t\n1549\t    async def test_cancel_message_replaced(self) -> None:\n1550\t        task = asyncio.current_task()\n1551\t        assert task\n1552\t        try:\n1553\t            task.cancel()\n1554\t            await checkpoint()\n1555\t        except asyncio.CancelledError:\n1556\t            try:\n1557\t                with CancelScope() as scope:\n1558\t                    scope.cancel()\n1559\t                    try:\n1560\t                        await checkpoint()\n1561\t                    except asyncio.CancelledError as exc:\n1562\t                        raise asyncio.CancelledError from exc\n1563\t            except asyncio.CancelledError:\n1564\t                pytest.fail(\"Should have swallowed the CancelledError\")\n1565\t\n1566\t    async def test_cancel_counter_nested_scopes(self) -> None:\n1567\t        with CancelScope() as root_scope:\n1568\t            with CancelScope():\n1569\t                root_scope.cancel()\n1570\t                await checkpoint()\n1571\t\n1572\t        assert not cast(asyncio.Task, asyncio.current_task()).cancelling()\n1573\t\n1574\t    async def test_uncancel_after_taskgroup_cancelled(self) -> None:\n1575\t        \"\"\"\n1576\t        Test that a cancel scope only uncancels the host task as many times as it has\n1577\t        cancelled that specific task, and won't count child task cancellations towards\n1578\t        that amount.\n1579\t        \"\"\"\n1580\t\n1581\t        async def child_task(task_status: TaskStatus[None]) -> None:\n1582\t            async with create_task_group() as tg:\n1583\t                tg.start_soon(sleep, 3)\n1584\t                await wait_all_tasks_blocked()\n1585\t                task_status.started()\n1586\t\n1587\t        task = asyncio.current_task()\n1588\t        assert task\n1589\t        with pytest.raises(CancelledError):\n1590\t            async with create_task_group() as tg:\n1591\t                await tg.start(child_task)\n1592\t                task.cancel()\n1593\t"}]},"parent_tool_use_id":null,"session_id":"59b59494-d0b0-4753-8d59-b446d84c323b","uuid":"0ac13690-029b-49df-805e-8ab55b6e9f17","timestamp":"2026-07-21T02:03:32.910Z","tool_use_result":{"type":"text","file":{"filePath":"/private/var/folders/hj/_j2mx6hd7_b1_pnjzwkktlsr0000gn/T/sidekick-anyio-start-task-handles-nzqv9xy3/tests/test_taskgroups.py","content":"async def test_start_soon_parent_id() -> None:\n    root_task_id = get_current_task().id\n    parent_id: int | None = None\n\n    async def subtask() -> None:\n        nonlocal parent_id\n        parent_id = get_current_task().parent_id\n\n    async def starter_task() -> None:\n        tg.start_soon(subtask)\n\n    async with anyio.create_task_group() as tg:\n        tg.start_soon(starter_task)\n\n    assert parent_id == root_task_id\n\n\nasync def test_start_parent_id() -> None:\n    root_task_id = get_current_task().id\n    starter_task_id: int | None = None\n    initial_parent_id: int | None = None\n    permanent_parent_id: int | None = None\n\n    async def subtask(*, task_status: TaskStatus) -> None:\n        nonlocal initial_parent_id, permanent_parent_id\n        initial_parent_id = get_current_task().parent_id\n        task_status.started()\n        permanent_parent_id = get_current_task().parent_id\n\n    async def starter_task() -> None:\n        nonlocal starter_task_id\n        starter_task_id = get_current_task().id\n        await tg.start(subtask)\n\n    async with anyio.create_task_group() as tg:\n        tg.start_soon(starter_task)\n\n    assert initial_parent_id != permanent_parent_id\n    assert initial_parent_id == starter_task_id\n    assert permanent_parent_id == root_task_id\n\n\n@pytest.mark.skipif(\n    sys.version_info < (3, 11),\n    reason=\"Task uncancelling is only supported on Python 3.11\",\n)\n@pytest.mark.parametrize(\"anyio_backend\", asyncio_params)\nclass TestUncancel:\n    async def test_uncancel_after_native_cancel(self) -> None:\n        task = cast(asyncio.Task, asyncio.current_task())\n        with pytest.raises(asyncio.CancelledError), CancelScope():\n            task.cancel()\n            await checkpoint()\n\n        assert task.cancelling() == 1\n        task.uncancel()\n\n    async def test_uncancel_after_scope_cancel(self) -> None:\n        task = cast(asyncio.Task, asyncio.current_task())\n        with CancelScope() as scope:\n            scope.cancel()\n            await checkpoint()\n\n        assert task.cancelling() == 0\n\n    async def test_uncancel_after_scope_and_native_cancel(self) -> None:\n        task = cast(asyncio.Task, asyncio.current_task())\n        with pytest.raises(asyncio.CancelledError), CancelScope() as scope:\n            scope.cancel()\n            task.cancel()\n            await checkpoint()\n\n        assert task.cancelling() == 1\n        task.uncancel()\n\n    async def test_cancel_message_replaced(self) -> None:\n        task = asyncio.current_task()\n        assert task\n        try:\n            task.cancel()\n            await checkpoint()\n        except asyncio.CancelledError:\n            try:\n                with CancelScope() as scope:\n                    scope.cancel()\n                    try:\n                        await checkpoint()\n                    except asyncio.CancelledError as exc:\n                        raise asyncio.CancelledError from exc\n            except asyncio.CancelledError:\n                pytest.fail(\"Should have swallowed the CancelledError\")\n\n    async def test_cancel_counter_nested_scopes(self) -> None:\n        with CancelScope() as root_scope:\n            with CancelScope():\n                root_scope.cancel()\n                await checkpoint()\n\n        assert not cast(asyncio.Task, asyncio.current_task()).cancelling()\n\n    async def test_uncancel_after_taskgroup_cancelled(self) -> None:\n        \"\"\"\n        Test that a cancel scope only uncancels the host task as many times as it has\n        cancelled that specific task, and won't count child task cancellations towards\n        that amount.\n        \"\"\"\n\n        async def child_task(task_status: TaskStatus[None]) -> None:\n            async with create_task_group() as tg:\n                tg.start_soon(sleep, 3)\n                await wait_all_tasks_blocked()\n                task_status.started()\n\n        task = asyncio.current_task()\n        assert task\n        with pytest.raises(CancelledError):\n            async with create_task_group() as tg:\n                await tg.start(child_task)\n                task.cancel()\n","numLines":120,"startLine":1474,"totalLines":2196}}}
{"type":"assistant","message":{"model":"claude-fable-5","id":"msg_011CdEP4g3skvXeg166dskdt","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01L1rYVoVcgRVAsUt5m71sRb","name":"Read","input":{"file_path":"/private/var/folders/hj/_j2mx6hd7_b1_pnjzwkktlsr0000gn/T/sidekick-anyio-start-task-handles-nzqv9xy3/tests/test_taskgroups.py","offset":1840,"limit":420},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":2,"cache_creation_input_tokens":4147,"cache_read_input_tokens":79122,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":4147},"output_tokens":34,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"59b59494-d0b0-4753-8d59-b446d84c323b","uuid":"7711f7cb-5578-485d-862a-f755e81291dd","timestamp":"2026-07-21T02:03:39.324Z","request_id":"req_011CdEP4eUNfxpD7KbHhTwBH"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01L1rYVoVcgRVAsUt5m71sRb","type":"tool_result","content":"1840\tclass TestTaskStatusTyping:\n1841\t    \"\"\"\n1842\t    These tests do not do anything at run time, but since the test suite is also checked\n1843\t    with a static type checker, it ensures that the `TaskStatus` typing works as\n1844\t    intended.\n1845\t    \"\"\"\n1846\t\n1847\t    async def typetest_None(*, task_status: TaskStatus[None]) -> None:\n1848\t        task_status.started()\n1849\t        task_status.started(None)\n1850\t\n1851\t    async def typetest_None_Union(*, task_status: TaskStatus[int | None]) -> None:\n1852\t        task_status.started()\n1853\t        task_status.started(None)\n1854\t\n1855\t    async def typetest_non_None(*, task_status: TaskStatus[int]) -> None:\n1856\t        # We use `type: ignore` and `--warn-unused-ignores` to get type checking errors\n1857\t        # if these ever stop failing.\n1858\t        task_status.started()  # type: ignore[call-arg]\n1859\t        task_status.started(None)  # type: ignore[arg-type]\n1860\t\n1861\t    async def typetest_variance_good(*, task_status: TaskStatus[float]) -> None:\n1862\t        task_status2: TaskStatus[int] = task_status\n1863\t        task_status2.started(0)\n1864\t\n1865\t    async def typetest_variance_bad(*, task_status: TaskStatus[int]) -> None:\n1866\t        # We use `type: ignore` and `--warn-unused-ignores` to get type checking errors\n1867\t        # if these ever stop failing.\n1868\t        task_status2: TaskStatus[float] = task_status  # type: ignore[assignment]\n1869\t        task_status2.started(0.0)\n1870\t\n1871\t    async def typetest_optional_status(\n1872\t        *,\n1873\t        task_status: TaskStatus[int] = TASK_STATUS_IGNORED,\n1874\t    ) -> None:\n1875\t        task_status.started(1)\n1876\t\n1877\t\n1878\t@pytest.mark.skipif(\n1879\t    sys.version_info < (3, 12),\n1880\t    reason=\"Eager task factories require Python 3.12\",\n1881\t)\n1882\t@pytest.mark.parametrize(\"anyio_backend\", [\"asyncio\"])\n1883\t@pytest.mark.parametrize(\"use_custom_eager_factory\", [False, True])\n1884\tasync def test_eager_task_factory(\n1885\t    request: FixtureRequest, use_custom_eager_factory: bool\n1886\t) -> None:\n1887\t    ran = False\n1888\t\n1889\t    async def sync_coro() -> None:\n1890\t        nonlocal ran\n1891\t        ran = True\n1892\t\n1893\t        # This should trigger fetching the task state\n1894\t        with CancelScope():  # noqa: ASYNC100\n1895\t            pass\n1896\t\n1897\t    def create_custom_task(\n1898\t        coro: Coroutine[Any, Any, Any], /, **kwargs: Any\n1899\t    ) -> asyncio.Task[Any]:\n1900\t        return asyncio.Task(coro, **kwargs)\n1901\t\n1902\t    loop = asyncio.get_running_loop()\n1903\t    old_task_factory = loop.get_task_factory()\n1904\t    if use_custom_eager_factory:\n1905\t        loop.set_task_factory(asyncio.create_eager_task_factory(create_custom_task))\n1906\t    else:\n1907\t        loop.set_task_factory(asyncio.eager_task_factory)\n1908\t\n1909\t    request.addfinalizer(lambda: loop.set_task_factory(old_task_factory))\n1910\t\n1911\t    async with create_task_group() as tg:\n1912\t        tg.start_soon(sync_coro)\n1913\t        assert not ran\n1914\t        tg.cancel_scope.cancel()\n1915\t\n1916\t\n1917\t@pytest.mark.parametrize(\"anyio_backend\", asyncio_params)\n1918\tasync def test_patched_asyncio_task(monkeypatch: MonkeyPatch) -> None:\n1919\t    monkeypatch.setattr(\n1920\t        asyncio,\n1921\t        \"Task\",\n1922\t        asyncio.tasks._PyTask,  # type: ignore[attr-defined]\n1923\t    )\n1924\t    async with create_task_group() as tg:\n1925\t        tg.start_soon(sleep, 0)\n1926\t\n1927\t\n1928\tasync def test_exception_groups_suppresses_exc_context() -> None:\n1929\t    with pytest.raises(\n1930\t        cast(type[ExceptionGroup[Exception]], ExceptionGroup)\n1931\t    ) as exc_info:\n1932\t        async with create_task_group():\n1933\t            raise Exception(\"Error\")\n1934\t\n1935\t    assert exc_info.value.__suppress_context__\n1936\t\n1937\t\n1938\tasync def test_cancel_reason() -> None:\n1939\t    with CancelScope() as scope:\n1940\t        scope.cancel(\"test reason\")\n1941\t        with pytest.raises(get_cancelled_exc_class()) as exc_info:\n1942\t            await checkpoint()\n1943\t\n1944\t    task = get_current_task()\n1945\t    assert task and task.name\n1946\t    exc_info.match(\"test reason\")\n1947\t    exc_info.match(task.name)\n1948\t\n1949\t\n1950\t@pytest.mark.parametrize(\n1951\t    \"native\",\n1952\t    [\n1953\t        pytest.param(False, id=\"anyio\"),\n1954\t        pytest.param(True, id=\"asyncio\"),\n1955\t    ],\n1956\t)\n1957\t@pytest.mark.skipif(sys.version_info < (3, 14), reason=\"Requires Python 3.14\")\n1958\t@pytest.mark.parametrize(\"anyio_backend\", asyncio_params)\n1959\tasync def test_asyncio_call_graph(native: bool) -> None:\n1960\t    graph: asyncio.FutureCallGraph | None = None\n1961\t\n1962\t    async def taskfunc(depth: int) -> None:\n1963\t        nonlocal graph\n1964\t\n1965\t        if depth == 2:\n1966\t            # The checkpoint is a workaround for eager factories where call graph\n1967\t            # capturing doesn't work before the first yield\n1968\t            await checkpoint()\n1969\t            graph = asyncio.capture_call_graph(asyncio.current_task(), depth=depth)\n1970\t            return\n1971\t\n1972\t        if native:\n1973\t            async with asyncio.TaskGroup() as tg:\n1974\t                tg.create_task(taskfunc(depth + 1), name=f\"depth-{depth + 1}\")\n1975\t        else:\n1976\t            async with create_task_group() as tg:\n1977\t                tg.start_soon(taskfunc, depth + 1, name=f\"depth-{depth + 1}\")\n1978\t\n1979\t    current_task = asyncio.current_task()\n1980\t    assert current_task is not None\n1981\t    current_task.set_name(\"root\")\n1982\t    await taskfunc(0)\n1983\t    assert graph is not None\n1984\t    assert isinstance(graph.future, asyncio.Task)\n1985\t    task_names: list[str] = [graph.future.get_name()]\n1986\t    while graph.awaited_by:\n1987\t        assert len(graph.awaited_by) == 1\n1988\t        graph = graph.awaited_by[0]\n1989\t        assert isinstance(graph.future, asyncio.Task)\n1990\t        task_names.append(graph.future.get_name())\n1991\t\n1992\t    assert task_names == [\"depth-2\", \"depth-1\", \"root\"]\n1993\t\n1994\t\n1995\tclass TestCreateTask:\n1996\t    async def test_coro_attr(self) -> None:\n1997\t        async def taskfunc() -> None:\n1998\t            pass\n1999\t\n2000\t        coro = taskfunc()\n2001\t        async with create_task_group() as tg:\n2002\t            handle = tg.create_task(coro)\n2003\t            assert handle.coro is coro\n2004\t\n2005\t    async def test_non_coro(self) -> None:\n2006\t        async def taskfunc() -> None:\n2007\t            pass\n2008\t\n2009\t        async with create_task_group() as tg:\n2010\t            with pytest.raises(TypeError, match=\"expected a coroutine, got \"):\n2011\t                tg.create_task(taskfunc)  # type: ignore[arg-type]\n2012\t\n2013\t    async def test_return_value(self) -> None:\n2014\t        async def taskfunc(x: int, y: int) -> int:\n2015\t            return x + y\n2016\t\n2017\t        async with create_task_group() as tg:\n2018\t            handle = tg.create_task(taskfunc(2, 4))\n2019\t            with pytest.raises(TaskNotFinished, match=\"the task has not finished yet\"):\n2020\t                handle.return_value  # noqa: B018\n2021\t\n2022\t            assert re.match(\n2023\t                r\"<TaskHandle pending \"\n2024\t                r\"name='TestCreateTask.test_return_value.<locals>.taskfunc' \"\n2025\t                r\"coro=<coroutine object(.+)>>\",\n2026\t                repr(handle),\n2027\t            )\n2028\t            assert await handle == 6\n2029\t            assert re.match(\n2030\t                r\"<TaskHandle finished \"\n2031\t                r\"name='TestCreateTask.test_return_value.<locals>.taskfunc' \"\n2032\t                r\"coro=<coroutine object(.+)>>\",\n2033\t                repr(handle),\n2034\t            )\n2035\t\n2036\t        assert handle.return_value == 6\n2037\t        assert handle.exception is None\n2038\t\n2039\t    async def test_exception(self) -> None:\n2040\t        async def taskfunc() -> NoReturn:\n2041\t            raise RuntimeError(\"dummy error\")\n2042\t\n2043\t        with pytest.RaisesGroup(pytest.RaisesExc(RuntimeError, match=\"dummy error\")):\n2044\t            async with create_task_group() as tg:\n2045\t                handle = tg.create_task(taskfunc())\n2046\t                with pytest.raises(\n2047\t                    TaskNotFinished, match=\"the task has not finished yet\"\n2048\t                ):\n2049\t                    handle.exception  # noqa: B018\n2050\t\n2051\t                with pytest.raises(TaskFailed, match=\"the task raised an exception\"):\n2052\t                    await handle\n2053\t\n2054\t                assert handle.status is TaskHandle.Status.FAILED\n2055\t\n2056\t        assert re.match(\n2057\t            r\"<TaskHandle failed \"\n2058\t            r\"name='TestCreateTask.test_exception.<locals>.taskfunc' \"\n2059\t            r\"coro=<coroutine object(.+)>\",\n2060\t            repr(handle),\n2061\t        )\n2062\t        assert isinstance(handle.exception, RuntimeError)\n2063\t        with pytest.raises(TaskFailed, match=\"the task raised an exception\"):\n2064\t            handle.return_value  # noqa: B018\n2065\t\n2066\t    def test_base_exception(\n2067\t        self, anyio_backend_name: str, anyio_backend_options: dict[str, Any]\n2068\t    ) -> None:\n2069\t        async def taskfunc() -> NoReturn:\n2070\t            raise SystemExit(5)\n2071\t\n2072\t        async def main() -> None:\n2073\t            async with create_task_group() as tg:\n2074\t                handle = tg.create_task(taskfunc())\n2075\t                with pytest.raises(TaskFailed, match=\"the task raised an exception\"):\n2076\t                    await handle\n2077\t\n2078\t                assert handle.status is TaskHandle.Status.FAILED\n2079\t                assert re.match(\n2080\t                    r\"<TaskHandle failed \"\n2081\t                    r\"name='TestCreateTask.test_base_exception.<locals>.taskfunc' \"\n2082\t                    r\"coro=<coroutine object(.+)>\",\n2083\t                    repr(handle),\n2084\t                )\n2085\t\n2086\t        with pytest.RaisesGroup(\n2087\t            pytest.RaisesExc(SystemExit, match=\"5\"), allow_unwrapped=True\n2088\t        ):\n2089\t            anyio.run(\n2090\t                main, backend=anyio_backend_name, backend_options=anyio_backend_options\n2091\t            )\n2092\t\n2093\t    @pytest.mark.parametrize(\"wait_until_running\", [True, False])\n2094\t    async def test_cancel(self, wait_until_running: bool) -> None:\n2095\t        \"\"\"\n2096\t        Test that the task function gets to run until the first\n2097\t        checkpoint when it's cancelled right after creation.\n2098\t        \"\"\"\n2099\t        task_started = False\n2100\t        event = Event()\n2101\t\n2102\t        async def taskfunc() -> None:\n2103\t            nonlocal task_started\n2104\t            task_started = True\n2105\t            await event.wait()\n2106\t\n2107\t        async with create_task_group() as tg:\n2108\t            handle = tg.create_task(taskfunc())\n2109\t            if wait_until_running:\n2110\t                await wait_all_tasks_blocked()\n2111\t\n2112\t            handle.cancel()\n2113\t            assert handle.status is TaskHandle.Status.CANCELLING\n2114\t            assert re.match(\n2115\t                r\"<TaskHandle cancelling \"\n2116\t                r\"name='TestCreateTask.test_cancel.<locals>.taskfunc' \"\n2117\t                r\"coro=<coroutine object(.+)>>\",\n2118\t                repr(handle),\n2119\t            )\n2120\t            with pytest.raises(TaskCancelled, match=\"the task was cancelled\"):\n2121\t                handle.return_value  # noqa: B018\n2122\t\n2123\t            with pytest.raises(TaskCancelled, match=\"the task was cancelled\"):\n2124\t                handle.exception  # noqa: B018\n2125\t\n2126\t            with pytest.raises(TaskCancelled, match=\"the task was cancelled\"):\n2127\t                await handle\n2128\t\n2129\t        with pytest.raises(TaskCancelled, match=\"the task was cancelled\") as exc_info:\n2130\t            await handle\n2131\t\n2132\t        assert isinstance(exc_info.value.__cause__, get_cancelled_exc_class())\n2133\t\n2134\t        assert handle.status is TaskHandle.Status.CANCELLED\n2135\t        assert task_started\n2136\t        assert re.match(\n2137\t            r\"<TaskHandle cancelled \"\n2138\t            r\"name='TestCreateTask.test_cancel.<locals>.taskfunc' \"\n2139\t            r\"coro=<coroutine object(.+)>>\",\n2140\t            repr(handle),\n2141\t        )\n2142\t\n2143\t    async def test_custom_context(self) -> None:\n2144\t        ctxvar = ContextVar[int](\"ctxvar\")\n2145\t        ctx = copy_context()\n2146\t        ctx.run(ctxvar.set, 42)\n2147\t\n2148\t        async def taskfunc() -> int:\n2149\t            return ctxvar.get()\n2150\t\n2151\t        assert ctxvar.get(None) is None\n2152\t        async with create_task_group() as tg:\n2153\t            assert await tg.create_task(taskfunc(), context=ctx) == 42\n2154\t\n2155\t    async def test_task_name_default(self) -> None:\n2156\t        async def taskfunc() -> str | None:\n2157\t            return get_current_task().name\n2158\t\n2159\t        async with create_task_group() as tg:\n2160\t            handle = tg.create_task(taskfunc())\n2161\t            assert re.match(\n2162\t                r\"<TaskHandle pending \"\n2163\t                r\"name='TestCreateTask.test_task_name_default.<locals>.taskfunc' \"\n2164\t                r\"coro=<coroutine object(.+)>>\",\n2165\t                repr(handle),\n2166\t            )\n2167\t            assert await handle == handle.name\n2168\t\n2169\t        assert handle.name == \"TestCreateTask.test_task_name_default.<locals>.taskfunc\"\n2170\t\n2171\t    async def test_task_name_custom_name(self) -> None:\n2172\t        async def taskfunc() -> None:\n2173\t            assert get_current_task().name == \"custom name\"\n2174\t\n2175\t        async with create_task_group() as tg:\n2176\t            handle = tg.create_task(taskfunc(), name=\"custom name\")\n2177\t            assert handle.name == \"custom name\"\n2178\t            assert re.match(\n2179\t                r\"<TaskHandle pending name='custom name' coro=<coroutine object(.+)>>\",\n2180\t                repr(handle),\n2181\t            )\n2182\t\n2183\t    async def test_wait(self) -> None:\n2184\t        async def taskfunc() -> None:\n2185\t            raise RuntimeError(\"dummy error\")\n2186\t\n2187\t        with pytest.RaisesGroup(pytest.RaisesExc(RuntimeError, match=\"dummy error\")):\n2188\t            async with create_task_group() as tg:\n2189\t                handle = tg.create_task(taskfunc())\n2190\t                assert handle.status is TaskHandle.Status.PENDING\n2191\t                await handle.wait()\n2192\t\n2193\t        assert str(handle.exception) == \"dummy error\"\n2194\t        assert handle.status is TaskHandle.Status.FAILED\n2195\t        await handle.wait()\n2196\t"}]},"parent_tool_use_id":null,"session_id":"59b59494-d0b0-4753-8d59-b446d84c323b","uuid":"d7522a58-39ba-424e-9c5d-d31b9d1745b2","timestamp":"2026-07-21T02:03:39.329Z","tool_use_result":{"type":"text","file":{"filePath":"/private/var/folders/hj/_j2mx6hd7_b1_pnjzwkktlsr0000gn/T/sidekick-anyio-start-task-handles-nzqv9xy3/tests/test_taskgroups.py","content":"class TestTaskStatusTyping:\n    \"\"\"\n    These tests do not do anything at run time, but since the test suite is also checked\n    with a static type checker, it ensures that the `TaskStatus` typing works as\n    intended.\n    \"\"\"\n\n    async def typetest_None(*, task_status: TaskStatus[None]) -> None:\n        task_status.started()\n        task_status.started(None)\n\n    async def typetest_None_Union(*, task_status: TaskStatus[int | None]) -> None:\n        task_status.started()\n        task_status.started(None)\n\n    async def typetest_non_None(*, task_status: TaskStatus[int]) -> None:\n        # We use `type: ignore` and `--warn-unused-ignores` to get type checking errors\n        # if these ever stop failing.\n        task_status.started()  # type: ignore[call-arg]\n        task_status.started(None)  # type: ignore[arg-type]\n\n    async def typetest_variance_good(*, task_status: TaskStatus[float]) -> None:\n        task_status2: TaskStatus[int] = task_status\n        task_status2.started(0)\n\n    async def typetest_variance_bad(*, task_status: TaskStatus[int]) -> None:\n        # We use `type: ignore` and `--warn-unused-ignores` to get type checking errors\n        # if these ever stop failing.\n        task_status2: TaskStatus[float] = task_status  # type: ignore[assignment]\n        task_status2.started(0.0)\n\n    async def typetest_optional_status(\n        *,\n        task_status: TaskStatus[int] = TASK_STATUS_IGNORED,\n    ) -> None:\n        task_status.started(1)\n\n\n@pytest.mark.skipif(\n    sys.version_info < (3, 12),\n    reason=\"Eager task factories require Python 3.12\",\n)\n@pytest.mark.parametrize(\"anyio_backend\", [\"asyncio\"])\n@pytest.mark.parametrize(\"use_custom_eager_factory\", [False, True])\nasync def test_eager_task_factory(\n    request: FixtureRequest, use_custom_eager_factory: bool\n) -> None:\n    ran = False\n\n    async def sync_coro() -> None:\n        nonlocal ran\n        ran = True\n\n        # This should trigger fetching the task state\n        with CancelScope():  # noqa: ASYNC100\n            pass\n\n    def create_custom_task(\n        coro: Coroutine[Any, Any, Any], /, **kwargs: Any\n    ) -> asyncio.Task[Any]:\n        return asyncio.Task(coro, **kwargs)\n\n    loop = asyncio.get_running_loop()\n    old_task_factory = loop.get_task_factory()\n    if use_custom_eager_factory:\n        loop.set_task_factory(asyncio.create_eager_task_factory(create_custom_task))\n    else:\n        loop.set_task_factory(asyncio.eager_task_factory)\n\n    request.addfinalizer(lambda: loop.set_task_factory(old_task_factory))\n\n    async with create_task_group() as tg:\n        tg.start_soon(sync_coro)\n        assert not ran\n        tg.cancel_scope.cancel()\n\n\n@pytest.mark.parametrize(\"anyio_backend\", asyncio_params)\nasync def test_patched_asyncio_task(monkeypatch: MonkeyPatch) -> None:\n    monkeypatch.setattr(\n        asyncio,\n        \"Task\",\n        asyncio.tasks._PyTask,  # type: ignore[attr-defined]\n    )\n    async with create_task_group() as tg:\n        tg.start_soon(sleep, 0)\n\n\nasync def test_exception_groups_suppresses_exc_context() -> None:\n    with pytest.raises(\n        cast(type[ExceptionGroup[Exception]], ExceptionGroup)\n    ) as exc_info:\n        async with create_task_group():\n            raise Exception(\"Error\")\n\n    assert exc_info.value.__suppress_context__\n\n\nasync def test_cancel_reason() -> None:\n    with CancelScope() as scope:\n        scope.cancel(\"test reason\")\n        with pytest.raises(get_cancelled_exc_class()) as exc_info:\n            await checkpoint()\n\n    task = get_current_task()\n    assert task and task.name\n    exc_info.match(\"test reason\")\n    exc_info.match(task.name)\n\n\n@pytest.mark.parametrize(\n    \"native\",\n    [\n        pytest.param(False, id=\"anyio\"),\n        pytest.param(True, id=\"asyncio\"),\n    ],\n)\n@pytest.mark.skipif(sys.version_info < (3, 14), reason=\"Requires Python 3.14\")\n@pytest.mark.parametrize(\"anyio_backend\", asyncio_params)\nasync def test_asyncio_call_graph(native: bool) -> None:\n    graph: asyncio.FutureCallGraph | None = None\n\n    async def taskfunc(depth: int) -> None:\n        nonlocal graph\n\n        if depth == 2:\n            # The checkpoint is a workaround for eager factories where call graph\n            # capturing doesn't work before the first yield\n            await checkpoint()\n            graph = asyncio.capture_call_graph(asyncio.current_task(), depth=depth)\n            return\n\n        if native:\n            async with asyncio.TaskGroup() as tg:\n                tg.create_task(taskfunc(depth + 1), name=f\"depth-{depth + 1}\")\n        else:\n            async with create_task_group() as tg:\n                tg.start_soon(taskfunc, depth + 1, name=f\"depth-{depth + 1}\")\n\n    current_task = asyncio.current_task()\n    assert current_task is not None\n    current_task.set_name(\"root\")\n    await taskfunc(0)\n    assert graph is not None\n    assert isinstance(graph.future, asyncio.Task)\n    task_names: list[str] = [graph.future.get_name()]\n    while graph.awaited_by:\n        assert len(graph.awaited_by) == 1\n        graph = graph.awaited_by[0]\n        assert isinstance(graph.future, asyncio.Task)\n        task_names.append(graph.future.get_name())\n\n    assert task_names == [\"depth-2\", \"depth-1\", \"root\"]\n\n\nclass TestCreateTask:\n    async def test_coro_attr(self) -> None:\n        async def taskfunc() -> None:\n            pass\n\n        coro = taskfunc()\n        async with create_task_group() as tg:\n            handle = tg.create_task(coro)\n            assert handle.coro is coro\n\n    async def test_non_coro(self) -> None:\n        async def taskfunc() -> None:\n            pass\n\n        async with create_task_group() as tg:\n            with pytest.raises(TypeError, match=\"expected a coroutine, got \"):\n                tg.create_task(taskfunc)  # type: ignore[arg-type]\n\n    async def test_return_value(self) -> None:\n        async def taskfunc(x: int, y: int) -> int:\n            return x + y\n\n        async with create_task_group() as tg:\n            handle = tg.create_task(taskfunc(2, 4))\n            with pytest.raises(TaskNotFinished, match=\"the task has not finished yet\"):\n                handle.return_value  # noqa: B018\n\n            assert re.match(\n                r\"<TaskHandle pending \"\n                r\"name='TestCreateTask.test_return_value.<locals>.taskfunc' \"\n                r\"coro=<coroutine object(.+)>>\",\n                repr(handle),\n            )\n            assert await handle == 6\n            assert re.match(\n                r\"<TaskHandle finished \"\n                r\"name='TestCreateTask.test_return_value.<locals>.taskfunc' \"\n                r\"coro=<coroutine object(.+)>>\",\n                repr(handle),\n            )\n\n        assert handle.return_value == 6\n        assert handle.exception is None\n\n    async def test_exception(self) -> None:\n        async def taskfunc() -> NoReturn:\n            raise RuntimeError(\"dummy error\")\n\n        with pytest.RaisesGroup(pytest.RaisesExc(RuntimeError, match=\"dummy error\")):\n            async with create_task_group() as tg:\n                handle = tg.create_task(taskfunc())\n                with pytest.raises(\n                    TaskNotFinished, match=\"the task has not finished yet\"\n                ):\n                    handle.exception  # noqa: B018\n\n                with pytest.raises(TaskFailed, match=\"the task raised an exception\"):\n                    await handle\n\n                assert handle.status is TaskHandle.Status.FAILED\n\n        assert re.match(\n            r\"<TaskHandle failed \"\n            r\"name='TestCreateTask.test_exception.<locals>.taskfunc' \"\n            r\"coro=<coroutine object(.+)>\",\n            repr(handle),\n        )\n        assert isinstance(handle.exception, RuntimeError)\n        with pytest.raises(TaskFailed, match=\"the task raised an exception\"):\n            handle.return_value  # noqa: B018\n\n    def test_base_exception(\n        self, anyio_backend_name: str, anyio_backend_options: dict[str, Any]\n    ) -> None:\n        async def taskfunc() -> NoReturn:\n            raise SystemExit(5)\n\n        async def main() -> None:\n            async with create_task_group() as tg:\n                handle = tg.create_task(taskfunc())\n                with pytest.raises(TaskFailed, match=\"the task raised an exception\"):\n                    await handle\n\n                assert handle.status is TaskHandle.Status.FAILED\n                assert re.match(\n                    r\"<TaskHandle failed \"\n                    r\"name='TestCreateTask.test_base_exception.<locals>.taskfunc' \"\n                    r\"coro=<coroutine object(.+)>\",\n                    repr(handle),\n                )\n\n        with pytest.RaisesGroup(\n            pytest.RaisesExc(SystemExit, match=\"5\"), allow_unwrapped=True\n        ):\n            anyio.run(\n                main, backend=anyio_backend_name, backend_options=anyio_backend_options\n            )\n\n    @pytest.mark.parametrize(\"wait_until_running\", [True, False])\n    async def test_cancel(self, wait_until_running: bool) -> None:\n        \"\"\"\n        Test that the task function gets to run until the first\n        checkpoint when it's cancelled right after creation.\n        \"\"\"\n        task_started = False\n        event = Event()\n\n        async def taskfunc() -> None:\n            nonlocal task_started\n            task_started = True\n            await event.wait()\n\n        async with create_task_group() as tg:\n            handle = tg.create_task(taskfunc())\n            if wait_until_running:\n                await wait_all_tasks_blocked()\n\n            handle.cancel()\n            assert handle.status is TaskHandle.Status.CANCELLING\n            assert re.match(\n                r\"<TaskHandle cancelling \"\n                r\"name='TestCreateTask.test_cancel.<locals>.taskfunc' \"\n                r\"coro=<coroutine object(.+)>>\",\n                repr(handle),\n            )\n            with pytest.raises(TaskCancelled, match=\"the task was cancelled\"):\n                handle.return_value  # noqa: B018\n\n            with pytest.raises(TaskCancelled, match=\"the task was cancelled\"):\n                handle.exception  # noqa: B018\n\n            with pytest.raises(TaskCancelled, match=\"the task was cancelled\"):\n                await handle\n\n        with pytest.raises(TaskCancelled, match=\"the task was cancelled\") as exc_info:\n            await handle\n\n        assert isinstance(exc_info.value.__cause__, get_cancelled_exc_class())\n\n        assert handle.status is TaskHandle.Status.CANCELLED\n        assert task_started\n        assert re.match(\n            r\"<TaskHandle cancelled \"\n            r\"name='TestCreateTask.test_cancel.<locals>.taskfunc' \"\n            r\"coro=<coroutine object(.+)>>\",\n            repr(handle),\n        )\n\n    async def test_custom_context(self) -> None:\n        ctxvar = ContextVar[int](\"ctxvar\")\n        ctx = copy_context()\n        ctx.run(ctxvar.set, 42)\n\n        async def taskfunc() -> int:\n            return ctxvar.get()\n\n        assert ctxvar.get(None) is None\n        async with create_task_group() as tg:\n            assert await tg.create_task(taskfunc(), context=ctx) == 42\n\n    async def test_task_name_default(self) -> None:\n        async def taskfunc() -> str | None:\n            return get_current_task().name\n\n        async with create_task_group() as tg:\n            handle = tg.create_task(taskfunc())\n            assert re.match(\n                r\"<TaskHandle pending \"\n                r\"name='TestCreateTask.test_task_name_default.<locals>.taskfunc' \"\n                r\"coro=<coroutine object(.+)>>\",\n                repr(handle),\n            )\n            assert await handle == handle.name\n\n        assert handle.name == \"TestCreateTask.test_task_name_default.<locals>.taskfunc\"\n\n    async def test_task_name_custom_name(self) -> None:\n        async def taskfunc() -> None:\n            assert get_current_task().name == \"custom name\"\n\n        async with create_task_group() as tg:\n            handle = tg.create_task(taskfunc(), name=\"custom name\")\n            assert handle.name == \"custom name\"\n            assert re.match(\n                r\"<TaskHandle pending name='custom name' coro=<coroutine object(.+)>>\",\n                repr(handle),\n            )\n\n    async def test_wait(self) -> None:\n        async def taskfunc() -> None:\n            raise RuntimeError(\"dummy error\")\n\n        with pytest.RaisesGroup(pytest.RaisesExc(RuntimeError, match=\"dummy error\")):\n            async with create_task_group() as tg:\n                handle = tg.create_task(taskfunc())\n                assert handle.status is TaskHandle.Status.PENDING\n                await handle.wait()\n\n        assert str(handle.exception) == \"dummy error\"\n        assert handle.status is TaskHandle.Status.FAILED\n        await handle.wait()\n","numLines":357,"startLine":1840,"totalLines":2196}}}
