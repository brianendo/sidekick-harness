elled_not_caught() -> None:\n771:async def test_cancelled_scope_based_checkpoint() -> None:\n788:async def test_cancelled_raises_beyond_origin_unshielded() -> None:\n807:async def test_cancelled_raises_beyond_origin_shielded() -> None:\n829:async def test_empty_taskgroup_contains_yield_point() -> None:\n850:async def test_cancel_host_asyncgen() -> None:\n881:async def test_shielding_immediate_scope_cancelled() -> None:\n896:async def test_shielding_mutate() -> None:\n921:async def test_cancel_scope_in_child_task() -> None:\n942:async def test_exception_cancels_siblings() -> None:\n964:async def test_cancel_cascade() -> None:\n977:async def test_cancelled_parent() -> None:\n993:async def test_shielded_deadline() -> None:\n1001:async def test_deadline_reached_on_start() -> None:\n1007:async def test_deadline_moved() -> None:\n1013:async def test_timeout_error_with_multiple_cancellations() -> None:\n1021:async def test_nested_fail_after() -> None:\n1041:async def test_nested_shield() -> None:\n1058:async def test_triple_nested_shield_checkpoint_in_outer() -> None:\n1082:async def test_triple_nested_shield_checkpoint_in_middle() -> None:\n1103:async def test_nested_task_group_filtering() -> None:\n1129:async def test_exception_group_filtering() -> None:\n1169:async def test_nested_exception_group_filtering() -> None:\n1209:async def test_cancel_propagation_with_inner_spawn() -> None:\n1223:async def test_escaping_cancelled_error_from_cancelled_task() -> None:\n1242:def test_cancel_generator_based_task() -> None:\n1264:async def test_schedule_old_style_coroutine_func() -> None:\n1287:async def test_cancel_native_future_tasks() -> None:\n1298:async def test_cancel_native_future_tasks_cancel_scope() -> None:\n1310:async def test_cancel_completed_task() -> None:\n1333:async def test_task_in_sync_spawn_callback() -> None:\n1353:async def test_shielded_cancel_sleep_time() -> None:\n1381:async def test_cancelscope_wrong_exit_order() -> None:\n1394:async def test_cancelscope_exit_before_enter() -> None:\n1407:async def test_cancelscope_exit_in_wrong_task() -> None:\n1428:def test_unhandled_exception_group(caplog: pytest.LogCaptureFixture) -> None:\n1452:async def test_single_cancellation_exc() -> None:\n1474:async def test_start_soon_parent_id() -> None:\n1491:async def test_start_parent_id() -> None:\n1521:class TestUncancel:\n1522:    async def test_uncancel_after_native_cancel(self) -> None:\n1531:    async def test_uncancel_after_scope_cancel(self) -> None:\n1539:    async def test_uncancel_after_scope_and_native_cancel(self) -> None:\n1549:    async def test_cancel_message_replaced(self) -> None:\n1566:    async def test_cancel_counter_nested_scopes(self) -> None:\n1574:    async def test_uncancel_after_taskgroup_cancelled(self) -> None:\n1596:    async def test_uncancel_after_group_aexit_native_cancel(self) -> None:\n1625:    async def test_uncancel_after_child_task_failed(self) -> None:\n1637:    async def test_uncancel_cancelled_scope_based_checkpoint(self) -> None:\n1658:async def test_taskgroup_reentry() -> None:\n1671:async def test_cancel_before_entering_task_group() -> None:\n1681:async def test_reraise_cancelled_in_excgroup() -> None:\n1690:async def test_cancel_child_task_when_host_is_shielded() -> None:\n1713:async def test_start_cancels_parent_scope() -> None:\n1738:class TestRefcycles:\n1739:    async def test_exception_refcycles_direct(self) -> None:\n1761:    async def test_exception_refcycles_errors(self) -> None:\n1778:    async def test_exception_refcycles_parent_task(self) -> None:\n1799:    async def test_exception_refcycles_propagate_cancellation_error(self) -> None:\n1816:    async def test_exception_refcycles_base_error(self) -> None:\n1840:class TestTaskStatusTyping:\n1884:async def test_eager_task_factory(\n1918:async def test_patched_asyncio_task(monkeypatch: MonkeyPatch) -> None:\n1928:async def test_exception_groups_suppresses_exc_context() -> None:\n1938:async def test_cancel_reason() -> None:\n1959:async def test_asyncio_call_graph(native: bool) -> None:\n1995:class TestCreateTask:\n1996:    async def test_coro_attr(self) -> None:\n2005:    async def test_non_coro(self) -> None:\n2013:    async def test_return_value(self) -> None:\n2039:    async def test_exception(self) -> None:\n2066:    def test_base_exception(\n2094:    async def test_cancel(self, wait_until_running: bool) -> None:","stderr":"","interrupted":false,"isImage":false,"noOutputExpected":false}}
{"type":"assistant","message":{"model":"claude-fable-5","id":"msg_011CdEP1Mg16BLK8LpQS9BYf","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01KEoZWWY9q1U3kiFfgFynyY","name":"Read","input":{"file_path":"/private/var/folders/hj/_j2mx6hd7_b1_pnjzwkktlsr0000gn/T/sidekick-anyio-start-task-handles-nzqv9xy3/tests/test_taskgroups.py","offset":1,"limit":360},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":2,"cache_creation_input_tokens":3506,"cache_read_input_tokens":70580,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":3506},"output_tokens":37,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"59b59494-d0b0-4753-8d59-b446d84c323b","uuid":"a14ed3f6-4d5d-420e-837e-29cca7c95c19","timestamp":"2026-07-21T02:02:53.971Z","request_id":"req_011CdEP1HUzEp4ordBw6Z4t9"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01KEoZWWY9q1U3kiFfgFynyY","type":"tool_result","content":"1\tfrom __future__ import annotations\n2\t\n3\timport asyncio\n4\timport gc\n5\timport math\n6\timport re\n7\timport sys\n8\timport time\n9\tfrom asyncio import CancelledError\n10\tfrom collections.abc import AsyncGenerator, Coroutine, Generator\n11\tfrom contextvars import ContextVar, copy_context\n12\tfrom typing import Any, NoReturn, cast\n13\tfrom unittest import mock\n14\t\n15\timport pytest\n16\tfrom pytest import FixtureRequest, MonkeyPatch\n17\t\n18\timport anyio\n19\tfrom anyio import (\n20\t    TASK_STATUS_IGNORED,\n21\t    CancelScope,\n22\t    Event,\n23\t    TaskCancelled,\n24\t    TaskFailed,\n25\t    TaskHandle,\n26\t    TaskNotFinished,\n27\t    create_task_group,\n28\t    current_effective_deadline,\n29\t    current_time,\n30\t    fail_after,\n31\t    get_cancelled_exc_class,\n32\t    get_current_task,\n33\t    move_on_after,\n34\t    sleep,\n35\t    sleep_forever,\n36\t    wait_all_tasks_blocked,\n37\t)\n38\tfrom anyio.abc import TaskGroup, TaskStatus\n39\tfrom anyio.lowlevel import checkpoint\n40\t\n41\tfrom .conftest import asyncio_params, no_other_refs\n42\t\n43\tif sys.version_info < (3, 11):\n44\t    from exceptiongroup import BaseExceptionGroup, ExceptionGroup\n45\t\n46\t\n47\tasync def async_error(text: str, delay: float = 0.1) -> NoReturn:\n48\t    try:\n49\t        if delay:\n50\t            await sleep(delay)\n51\t    finally:\n52\t        raise Exception(text)\n53\t\n54\t\n55\tasync def test_already_closed() -> None:\n56\t    async with create_task_group() as tg:\n57\t        pass\n58\t\n59\t    with pytest.raises(RuntimeError) as exc:\n60\t        tg.start_soon(async_error, \"fail\")\n61\t\n62\t    exc.match(\"This task group is not active; no new tasks can be started\")\n63\t\n64\t\n65\tasync def test_success() -> None:\n66\t    async def async_add(value: str) -> None:\n67\t        results.add(value)\n68\t\n69\t    results: set[str] = set()\n70\t    async with create_task_group() as tg:\n71\t        tg.start_soon(async_add, \"a\")\n72\t        tg.start_soon(async_add, \"b\")\n73\t\n74\t    assert results == {\"a\", \"b\"}\n75\t\n76\t\n77\t@pytest.mark.parametrize(\n78\t    \"modulename\",\n79\t    [\n80\t        pytest.param(\"asyncio\"),\n81\t        pytest.param(\"trio\"),\n82\t    ],\n83\t)\n84\tdef test_run_natively(modulename: str) -> None:\n85\t    async def testfunc() -> None:\n86\t        async with create_task_group() as tg:\n87\t            tg.start_soon(sleep, 0)\n88\t\n89\t    module = pytest.importorskip(modulename, reason=f\"{modulename} is not available\")\n90\t    if module is asyncio:\n91\t        asyncio.run(testfunc())\n92\t    else:\n93\t        module.run(testfunc)\n94\t\n95\t\n96\tasync def test_start_soon_while_running() -> None:\n97\t    async def task_func() -> None:\n98\t        tg.start_soon(sleep, 0)\n99\t\n100\t    async with create_task_group() as tg:\n101\t        tg.start_soon(task_func)\n102\t\n103\t\n104\tasync def test_start_soon_after_error() -> None:\n105\t    with pytest.raises(ExceptionGroup):\n106\t        async with create_task_group() as tg:\n107\t            a = 1 / 0  # noqa: F841\n108\t\n109\t    with pytest.raises(RuntimeError) as exc:\n110\t        tg.start_soon(sleep, 0)\n111\t\n112\t    exc.match(\"This task group is not active; no new tasks can be started\")\n113\t\n114\t\n115\tasync def test_start_no_value() -> None:\n116\t    async def taskfunc(*, task_status: TaskStatus) -> None:\n117\t        task_status.started()\n118\t\n119\t    async with create_task_group() as tg:\n120\t        value = await tg.start(taskfunc)\n121\t        assert value is None\n122\t\n123\t\n124\tasync def test_start_called_twice() -> None:\n125\t    async def taskfunc(*, task_status: TaskStatus) -> None:\n126\t        task_status.started()\n127\t\n128\t        with pytest.raises(\n129\t            RuntimeError, match=\"called 'started' twice on the same task status\"\n130\t        ):\n131\t            task_status.started()\n132\t\n133\t    async with create_task_group() as tg:\n134\t        value = await tg.start(taskfunc)\n135\t        assert value is None\n136\t\n137\t\n138\tasync def test_no_called_started_twice() -> None:\n139\t    async def taskfunc(*, task_status: TaskStatus) -> None:\n140\t        task_status.started()\n141\t\n142\t    async with create_task_group() as tg:\n143\t        coro = tg.start(taskfunc)\n144\t        tg.cancel_scope.cancel()\n145\t        await coro\n146\t\n147\t\n148\tasync def test_start_with_value() -> None:\n149\t    async def taskfunc(*, task_status: TaskStatus[str]) -> None:\n150\t        task_status.started(\"foo\")\n151\t\n152\t    async with create_task_group() as tg:\n153\t        value = await tg.start(taskfunc)\n154\t        assert value == \"foo\"\n155\t\n156\t\n157\tasync def test_start_crash_before_started_call() -> None:\n158\t    async def taskfunc(*, task_status: TaskStatus) -> NoReturn:\n159\t        raise Exception(\"foo\")\n160\t\n161\t    async with create_task_group() as tg:\n162\t        with pytest.raises(Exception) as exc:\n163\t            await tg.start(taskfunc)\n164\t\n165\t    exc.match(\"foo\")\n166\t\n167\t\n168\tasync def test_start_crash_after_started_call() -> None:\n169\t    async def taskfunc(*, task_status: TaskStatus[int]) -> NoReturn:\n170\t        task_status.started(2)\n171\t        raise Exception(\"foo\")\n172\t\n173\t    with pytest.raises(ExceptionGroup) as exc:\n174\t        async with create_task_group() as tg:\n175\t            value = await tg.start(taskfunc)\n176\t\n177\t    assert len(exc.value.exceptions) == 1\n178\t    assert str(exc.value.exceptions[0]) == \"foo\"\n179\t    assert value == 2\n180\t\n181\t\n182\tasync def test_start_no_started_call() -> None:\n183\t    async def taskfunc(*, task_status: TaskStatus) -> None:\n184\t        pass\n185\t\n186\t    async with create_task_group() as tg:\n187\t        with pytest.raises(RuntimeError) as exc:\n188\t            await tg.start(taskfunc)\n189\t\n190\t    exc.match(\"hild exited\")\n191\t\n192\t\n193\tasync def test_start_cancelled() -> None:\n194\t    started = finished = False\n195\t\n196\t    async def taskfunc(*, task_status: TaskStatus) -> None:\n197\t        nonlocal started, finished\n198\t        started = True\n199\t        await sleep(2)\n200\t        finished = True\n201\t\n202\t    async with create_task_group() as tg:\n203\t        tg.cancel_scope.cancel()\n204\t        await tg.start(taskfunc)\n205\t\n206\t    assert started\n207\t    assert not finished\n208\t\n209\t\n210\t@pytest.mark.parametrize(\"anyio_backend\", asyncio_params)\n211\tasync def test_start_native_host_cancelled() -> None:\n212\t    started = finished = False\n213\t\n214\t    async def taskfunc(*, task_status: TaskStatus) -> None:\n215\t        nonlocal started, finished\n216\t        started = True\n217\t        await sleep(2)\n218\t        finished = True\n219\t\n220\t    async def start_another() -> None:\n221\t        async with create_task_group() as tg:\n222\t            await tg.start(taskfunc)\n223\t\n224\t    task = asyncio.get_running_loop().create_task(start_another())\n225\t    await wait_all_tasks_blocked()\n226\t    task.cancel()\n227\t    with pytest.raises(asyncio.CancelledError):\n228\t        await task\n229\t\n230\t    assert started\n231\t    assert not finished\n232\t\n233\t\n234\t@pytest.mark.parametrize(\"anyio_backend\", asyncio_params)\n235\tasync def test_start_native_child_cancelled() -> None:\n236\t    task = None\n237\t    finished = False\n238\t\n239\t    async def taskfunc(*, task_status: TaskStatus) -> None:\n240\t        nonlocal task, finished\n241\t        task = asyncio.current_task()\n242\t        await sleep(2)\n243\t        finished = True\n244\t\n245\t    async def start_another() -> None:\n246\t        async with create_task_group() as tg2:\n247\t            await tg2.start(taskfunc)\n248\t\n249\t    async with create_task_group() as tg:\n250\t        tg.start_soon(start_another)\n251\t        await wait_all_tasks_blocked()\n252\t        assert task is not None\n253\t        task.cancel()\n254\t\n255\t    assert not finished\n256\t\n257\t\n258\t@pytest.mark.parametrize(\"anyio_backend\", asyncio_params)\n259\tasync def test_propagate_native_cancellation_from_taskgroup() -> None:\n260\t    async def taskfunc() -> None:\n261\t        async with create_task_group() as tg:\n262\t            tg.start_soon(asyncio.sleep, 2)\n263\t\n264\t    task = asyncio.create_task(taskfunc())\n265\t    await wait_all_tasks_blocked()\n266\t    task.cancel()\n267\t    with pytest.raises(asyncio.CancelledError):\n268\t        await task\n269\t\n270\t\n271\t@pytest.mark.parametrize(\"anyio_backend\", asyncio_params)\n272\tasync def test_cancel_with_nested_task_groups() -> None:\n273\t    \"\"\"Regression test for #695.\"\"\"\n274\t\n275\t    from anyio._backends import _asyncio\n276\t\n277\t    class EditableCancelScope(_asyncio.CancelScope):\n278\t        pass\n279\t\n280\t    async def shield_task() -> None:\n281\t        with EditableCancelScope(shield=True) as scope:\n282\t            with mock.patch.object(\n283\t                scope,\n284\t                \"_deliver_cancellation\",\n285\t                wraps=getattr(scope, \"_deliver_cancellation\"),\n286\t            ) as shielded_cancel_spy:\n287\t                await sleep(0.5)\n288\t\n289\t                assert len(outer_cancel_spy.call_args_list) < 10\n290\t                shielded_cancel_spy.assert_not_called()\n291\t\n292\t    async def middle_task() -> None:\n293\t        try:\n294\t            async with create_task_group() as tg:\n295\t                with mock.patch.object(\n296\t                    tg.cancel_scope,\n297\t                    \"_deliver_cancellation\",\n298\t                    wraps=getattr(tg.cancel_scope, \"_deliver_cancellation\"),\n299\t                ) as middle_cancel_spy:\n300\t                    tg.start_soon(shield_task, name=\"shield task\")\n301\t        finally:\n302\t            assert len(middle_cancel_spy.call_args_list) < 10\n303\t            assert len(outer_cancel_spy.call_args_list) < 10\n304\t\n305\t    with mock.patch.object(_asyncio, \"CancelScope\", EditableCancelScope):\n306\t        async with create_task_group() as tg:\n307\t            with mock.patch.object(\n308\t                tg.cancel_scope,\n309\t                \"_deliver_cancellation\",\n310\t                wraps=getattr(tg.cancel_scope, \"_deliver_cancellation\"),\n311\t            ) as outer_cancel_spy:\n312\t                tg.start_soon(middle_task, name=\"middle task\")\n313\t                await wait_all_tasks_blocked()\n314\t                tg.cancel_scope.cancel()\n315\t\n316\t    assert len(outer_cancel_spy.call_args_list) < 10\n317\t\n318\t\n319\tasync def test_start_exception_delivery(anyio_backend_name: str) -> None:\n320\t    def task_fn(*, task_status: TaskStatus[str] = TASK_STATUS_IGNORED) -> None:\n321\t        task_status.started(\"hello\")\n322\t\n323\t    if anyio_backend_name == \"trio\":\n324\t        pattern = \"appears to be synchronous\"\n325\t    else:\n326\t        pattern = \"is not a coroutine object\"\n327\t\n328\t    async with anyio.create_task_group() as tg:\n329\t        with pytest.raises(TypeError, match=pattern):\n330\t            await tg.start(task_fn)  # type: ignore[arg-type]\n331\t\n332\t\n333\tasync def test_start_cancel_after_error() -> None:\n334\t    \"\"\"Regression test for #517.\"\"\"\n335\t    sleep_completed = False\n336\t\n337\t    async def sleep_and_raise() -> None:\n338\t        await wait_all_tasks_blocked()\n339\t        raise RuntimeError(\"This should cancel the second start() call\")\n340\t\n341\t    async def sleep_only(task_status: TaskStatus[None]) -> None:\n342\t        nonlocal sleep_completed\n343\t        await sleep(1)\n344\t        sleep_completed = True\n345\t        task_status.started()\n346\t\n347\t    with pytest.raises(ExceptionGroup) as exc:\n348\t        async with anyio.create_task_group() as outer_tg:\n349\t            async with anyio.create_task_group() as inner_tg:\n350\t                inner_tg.start_soon(sleep_and_raise)\n351\t                await outer_tg.start(sleep_only)\n352\t\n353\t    assert isinstance(exc.value.exceptions[0], ExceptionGroup)\n354\t    assert isinstance(exc.value.exceptions[0].exceptions[0], RuntimeError)\n355\t    assert not sleep_completed\n356\t\n357\t\n358\tasync def test_host_exception() -> None:\n359\t    result = None\n360\t"}]},"parent_tool_use_id":null,"session_id":"59b59494-d0b0-4753-8d59-b446d84c323b","uuid":"87e31791-84a4-4fe5-bacd-5f545b03bfa9","timestamp":"2026-07-21T02:02:53.982Z","tool_use_result":{"type":"text","file":{"filePath":"/private/var/folders/hj/_j2mx6hd7_b1_pnjzwkktlsr0000gn/T/sidekick-anyio-start-task-handles-nzqv9xy3/tests/test_taskgroups.py","content":"from __future__ import annotations\n\nimport asyncio\nimport gc\nimport math\nimport re\nimport sys\nimport time\nfrom asyncio import CancelledError\nfrom collections.abc import AsyncGenerator, Coroutine, Generator\nfrom contextvars import ContextVar, copy_context\nfrom typing import Any, NoReturn, cast\nfrom unittest import mock\n\nimport pytest\nfrom pytest import FixtureRequest, MonkeyPatch\n\nimport anyio\nfrom anyio import (\n    TASK_STATUS_IGNORED,\n    CancelScope,\n    Event,\n    TaskCancelled,\n    TaskFailed,\n    TaskHandle,\n    TaskNotFinished,\n    create_task_group,\n    current_effective_deadline,\n    current_time,\n    fail_after,\n    get_cancelled_exc_class,\n    get_current_task,\n    move_on_after,\n    sleep,\n    sleep_forever,\n    wait_all_tasks_blocked,\n)\nfrom anyio.abc import TaskGroup, TaskStatus\nfrom anyio.lowlevel import checkpoint\n\nfrom .conftest import asyncio_params, no_other_refs\n\nif sys.version_info < (3, 11):\n    from exceptiongroup import BaseExceptionGroup, ExceptionGroup\n\n\nasync def async_error(text: str, delay: float = 0.1) -> NoReturn:\n    try:\n        if delay:\n            await sleep(delay)\n    finally:\n        raise Exception(text)\n\n\nasync def test_already_closed() -> None:\n    async with create_task_group() as tg:\n        pass\n\n    with pytest.raises(RuntimeError) as exc:\n        tg.start_soon(async_error, \"fail\")\n\n    exc.match(\"This task group is not active; no new tasks can be started\")\n\n\nasync def test_success() -> None:\n    async def async_add(value: str) -> None:\n        results.add(value)\n\n    results: set[str] = set()\n    async with create_task_group() as tg:\n        tg.start_soon(async_add, \"a\")\n        tg.start_soon(async_add, \"b\")\n\n    assert results == {\"a\", \"b\"}\n\n\n@pytest.mark.parametrize(\n    \"modulename\",\n    [\n        pytest.param(\"asyncio\"),\n        pytest.param(\"trio\"),\n    ],\n)\ndef test_run_natively(modulename: str) -> None:\n    async def testfunc() -> None:\n        async with create_task_group() as tg:\n            tg.start_soon(sleep, 0)\n\n    module = pytest.importorskip(modulename, reason=f\"{modulename} is not available\")\n    if module is asyncio:\n        asyncio.run(testfunc())\n    else:\n        module.run(testfunc)\n\n\nasync def test_start_soon_while_running() -> None:\n    async def task_func() -> None:\n        tg.start_soon(sleep, 0)\n\n    async with create_task_group() as tg:\n        tg.start_soon(task_func)\n\n\nasync def test_start_soon_after_error() -> None:\n    with pytest.raises(ExceptionGroup):\n        async with create_task_group() as tg:\n            a = 1 / 0  # noqa: F841\n\n    with pytest.raises(RuntimeError) as exc:\n        tg.start_soon(sleep, 0)\n\n    exc.match(\"This task group is not active; no new tasks can be started\")\n\n\nasync def test_start_no_value() -> None:\n    async def taskfunc(*, task_status: TaskStatus) -> None:\n        task_status.started()\n\n    async with create_task_group() as tg:\n        value = await tg.start(taskfunc)\n        assert value is None\n\n\nasync def test_start_called_twice() -> None:\n    async def taskfunc(*, task_status: TaskStatus) -> None:\n        task_status.started()\n\n        with pytest.raises(\n            RuntimeError, match=\"called 'started' twice on the same task status\"\n        ):\n            task_status.started()\n\n    async with create_task_group() as tg:\n        value = await tg.start(taskfunc)\n        assert value is None\n\n\nasync def test_no_called_started_twice() -> None:\n    async def taskfunc(*, task_status: TaskStatus) -> None:\n        task_status.started()\n\n    async with create_task_group() as tg:\n        coro = tg.start(taskfunc)\n        tg.cancel_scope.cancel()\n        await coro\n\n\nasync def test_start_with_value() -> None:\n    async def taskfunc(*, task_status: TaskStatus[str]) -> None:\n        task_status.started(\"foo\")\n\n    async with create_task_group() as tg:\n        value = await tg.start(taskfunc)\n        assert value == \"foo\"\n\n\nasync def test_start_crash_before_started_call() -> None:\n    async def taskfunc(*, task_status: TaskStatus) -> NoReturn:\n        raise Exception(\"foo\")\n\n    async with create_task_group() as tg:\n        with pytest.raises(Exception) as exc:\n            await tg.start(taskfunc)\n\n    exc.match(\"foo\")\n\n\nasync def test_start_crash_after_started_call() -> None:\n    async def taskfunc(*, task_status: TaskStatus[int]) -> NoReturn:\n        task_status.started(2)\n        raise Exception(\"foo\")\n\n    with pytest.raises(ExceptionGroup) as exc:\n        async with create_task_group() as tg:\n            value = await tg.start(taskfunc)\n\n    assert len(exc.value.exceptions) == 1\n    assert str(exc.value.exceptions[0]) == \"foo\"\n    assert value == 2\n\n\nasync def test_start_no_started_call() -> None:\n    async def taskfunc(*, task_status: TaskStatus) -> None:\n        pass\n\n    async with create_task_group() as tg:\n        with pytest.raises(RuntimeError) as exc:\n            await tg.start(taskfunc)\n\n    exc.match(\"hild exited\")\n\n\nasync def test_start_cancelled() -> None:\n    started = finished = False\n\n    async def taskfunc(*, task_status: TaskStatus) -> None:\n        nonlocal started, finished\n        started = True\n        await sleep(2)\n        finished = True\n\n    async with create_task_group() as tg:\n        tg.cancel_scope.cancel()\n        await tg.start(taskfunc)\n\n    assert started\n    assert not finished\n\n\n@pytest.mark.parametrize(\"anyio_backend\", asyncio_params)\nasync def test_start_native_host_cancelled() -> None:\n    started = finished = False\n\n    async def taskfunc(*, task_status: TaskStatus) -> None:\n        nonlocal started, finished\n        started = True\n        await sleep(2)\n        finished = True\n\n    async def start_another() -> None:\n        async with create_task_group() as tg:\n            await tg.start(taskfunc)\n\n    task = asyncio.get_running_loop().create_task(start_another())\n    await wait_all_tasks_blocked()\n    task.cancel()\n    with pytest.raises(asyncio.CancelledError):\n        await task\n\n    assert started\n    assert not finished\n\n\n@pytest.mark.parametrize(\"anyio_backend\", asyncio_params)\nasync def test_start_native_child_cancelled() -> None:\n    task = None\n    finished = False\n\n    async def taskfunc(*, task_status: TaskStatus) -> None:\n        nonlocal task, finished\n        task = asyncio.current_task()\n        await sleep(2)\n        finished = True\n\n    async def start_another() -> None:\n        async with create_task_group() as tg2:\n            await tg2.start(taskfunc)\n\n    async with create_task_group() as tg:\n        tg.start_soon(start_another)\n        await wait_all_tasks_blocked()\n        assert task is not None\n        task.cancel()\n\n    assert not finished\n\n\n@pytest.mark.parametrize(\"anyio_backend\", asyncio_params)\nasync def test_propagate_native_cancellation_from_taskgroup() -> None:\n    async def taskfunc() -> None:\n        async with create_task_group() as tg:\n            tg.start_soon(asyncio.sleep, 2)\n\n    task = asyncio.create_task(taskfunc())\n    await wait_all_tasks_blocked()\n    task.cancel()\n    with pytest.raises(asyncio.CancelledError):\n        await task\n\n\n@pytest.mark.parametrize(\"anyio_backend\", asyncio_params)\nasync def test_cancel_with_nested_task_groups() -> None:\n    \"\"\"Regression test for #695.\"\"\"\n\n    from anyio._backends import _asyncio\n\n    class EditableCancelScope(_asyncio.CancelScope):\n        pass\n\n    async def shield_task() -> None:\n        with EditableCancelScope(shield=True) as scope:\n            with mock.patch.object(\n                scope,\n                \"_deliver_cancellation\",\n                wraps=getattr(scope, \"_deliver_cancellation\"),\n            ) as shielded_cancel_spy:\n                await sleep(0.5)\n\n                assert len(outer_cancel_spy.call_args_list) < 10\n                shielded_cancel_spy.assert_not_called()\n\n    async def middle_task() -> None:\n        try:\n            async with create_task_group() as tg:\n                with mock.patch.object(\n                    tg.cancel_scope,\n                    \"_deliver_cancellation\",\n                    wraps=getattr(tg.cancel_scope, \"_deliver_cancellation\"),\n                ) as middle_cancel_spy:\n                    tg.start_soon(shield_task, name=\"shield task\")\n        finally:\n            assert len(middle_cancel_spy.call_args_list) < 10\n            assert len(outer_cancel_spy.call_args_list) < 10\n\n    with mock.patch.object(_asyncio, \"CancelScope\", EditableCancelScope):\n        async with create_task_group() as tg:\n            with mock.patch.object(\n                tg.cancel_scope,\n                \"_deliver_cancellation\",\n                wraps=getattr(tg.cancel_scope, \"_deliver_cancellation\"),\n            ) as outer_cancel_spy:\n                tg.start_soon(middle_task, name=\"middle task\")\n                await wait_all_tasks_blocked()\n                tg.cancel_scope.cancel()\n\n    assert len(outer_cancel_spy.call_args_list) < 10\n\n\nasync def test_start_exception_delivery(anyio_backend_name: str) -> None:\n    def task_fn(*, task_status: TaskStatus[str] = TASK_STATUS_IGNORED) -> None:\n        task_status.started(\"hello\")\n\n    if anyio_backend_name == \"trio\":\n        pattern = \"appears to be synchronous\"\n    else:\n        pattern = \"is not a coroutine object\"\n\n    async with anyio.create_task_group() as tg:\n        with pytest.raises(TypeError, match=pattern):\n            await tg.start(task_fn)  # type: ignore[arg-type]\n\n\nasync def test_start_cancel_after_error() -> None:\n    \"\"\"Regression test for #517.\"\"\"\n    sleep_completed = False\n\n    async def sleep_and_raise() -> None:\n        await wait_all_tasks_blocked()\n        raise RuntimeError(\"This should cancel the second start() call\")\n\n    async def sleep_only(task_status: TaskStatus[None]) -> None:\n        nonlocal sleep_completed\n        await sleep(1)\n        sleep_completed = True\n        task_status.started()\n\n    with pytest.raises(ExceptionGroup) as exc:\n        async with anyio.create_task_group() as outer_tg:\n            async with anyio.create_task_group() as inner_tg:\n                inner_tg.start_soon(sleep_and_raise)\n                await outer_tg.start(sleep_only)\n\n    assert isinstance(exc.value.exceptions[0], ExceptionGroup)\n    assert isinstance(exc.value.exceptions[0].exceptions[0], RuntimeError)\n    assert not sleep_completed\n\n\nasync def test_host_exception() -> None:\n    result = None\n","numLines":360,"startLine":1,"totalLines":2196}}}
