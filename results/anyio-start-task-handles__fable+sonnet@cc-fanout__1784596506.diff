+class TestStartSyncCallable:
+    """
+    Tests for passing start() a synchronous callable that signals readiness by calling
+    ``task_status.started()`` before returning the coroutine to run.
+    """
+
+    async def test_started_before_coro_returned(self) -> None:
+        task_ran = False
+
+        async def taskfunc() -> str:
+            nonlocal task_ran
+            task_ran = True
+            return "return value"
+
+        def wrapper(
+            arg: str, *, task_status: TaskStatus[str]
+        ) -> Coroutine[Any, Any, str]:
+            task_status.started(f"started:{arg}")
+            return taskfunc()
+
+        async with create_task_group() as tg:
+            value = await tg.start(wrapper, "foo")
+            assert value == "started:foo"
+
+        assert task_ran
+
+    async def test_started_before_coro_returned_no_value(self) -> None:
+        async def taskfunc() -> None:
+            pass
+
+        def wrapper(*, task_status: TaskStatus) -> Coroutine[Any, Any, None]:
+            task_status.started()
+            return taskfunc()
+
+        async with create_task_group() as tg:
+            assert await tg.start(wrapper) is None
+
+    async def test_return_handle(self) -> None:
+        async def taskfunc() -> str:
+            return "return value"
+
+        def wrapper(*, task_status: TaskStatus[str]) -> Coroutine[Any, Any, str]:
+            task_status.started("start value")
+            return taskfunc()
+
+        async with create_task_group() as tg:
+            handle = await tg.start(wrapper, return_handle=True)
+            assert isinstance(handle, TaskHandle)
+            assert handle.start_value == "start value"
+            assert await handle == "return value"
+
+    async def test_started_called_twice(self) -> None:
+        """
+        Calling started() twice before returning the coroutine must raise a
+        RuntimeError out of start() instead of delivering it to the task group.
+        """
+
+        async def taskfunc() -> None:
+            pass
+
+        def wrapper(*, task_status: TaskStatus[int]) -> Coroutine[Any, Any, None]:
+            task_status.started(1)
+            task_status.started(2)
+            return taskfunc()
+
+        async with create_task_group() as tg:
+            with pytest.raises(
+                RuntimeError, match="called 'started' twice on the same task status"
+            ):
+                await tg.start(wrapper)
+
+    async def test_started_twice_in_task_after_sync_start(self) -> None:
+        """
+        A second started() call from within the spawned task must raise a RuntimeError
+        in the task, delivering it to the task group.
+        """
+        wrapper_status: TaskStatus[int] | None = None
+
+        async def taskfunc() -> None:
+            assert wrapper_status is not None
+            wrapper_status.started(2)
+
+        def wrapper(*, task_status: TaskStatus[int]) -> Coroutine[Any, Any, None]:
+            nonlocal wrapper_status
+            wrapper_status = task_status
+            task_status.started(1)
+            return taskfunc()
+
+        with pytest.RaisesGroup(
+            pytest.RaisesExc(
+                RuntimeError, match="called 'started' twice on the same task status"
+            )
+        ):
+            async with create_task_group() as tg:
+                assert await tg.start(wrapper) == 1
+
+    async def test_exception_in_task(self) -> None:
+        """
+        An exception raised by the task after a synchronous started() call must be
