+class TestStartHandle:
+    async def test_default_returns_start_value(self) -> None:
+        """The default (no return_handle) behavior must remain unchanged."""
+
+        async def taskfunc(*, task_status: TaskStatus[str]) -> None:
+            task_status.started("start value")
+
+        async with create_task_group() as tg:
+            value = await tg.start(taskfunc)
+            assert value == "start value"
+            assert not isinstance(value, TaskHandle)
+
+    async def test_return_handle(self) -> None:
+        async def taskfunc(*, task_status: TaskStatus[str]) -> str:
+            task_status.started("start value")
+            return "return value"
+
+        async with create_task_group() as tg:
+            handle = await tg.start(taskfunc, return_handle=True)
+            assert isinstance(handle, TaskHandle)
+            assert handle.start_value == "start value"
+            assert await handle == "return value"
+
+        assert handle.status is TaskHandle.Status.FINISHED
+
+    async def test_return_handle_no_start_value(self) -> None:
+        async def taskfunc(*, task_status: TaskStatus) -> str:
+            task_status.started()
+            return "return value"
+
+        async with create_task_group() as tg:
+            handle = await tg.start(taskfunc, return_handle=True)
+            assert isinstance(handle, TaskHandle)
+            assert handle.start_value is None
+            assert await handle == "return value"
+
+    async def test_return_handle_cancel(self) -> None:
+        async def taskfunc(*, task_status: TaskStatus) -> None:
+            task_status.started()
+            await sleep_forever()
+
+        async with create_task_group() as tg:
+            handle = await tg.start(taskfunc, return_handle=True)
+            handle.cancel()
+            with pytest.raises(TaskCancelled, match="the task was cancelled"):
+                await handle
+
+        assert handle.status is TaskHandle.Status.CANCELLED
+        assert not tg.cancel_scope.cancel_called
