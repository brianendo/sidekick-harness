+    @t.skip.if_pypy
+    @patch('billiard.pool.Pool._create_worker_process')
+    def test_flush_keeps_busy_marker_for_running_job(self, _create_worker_process):
+        """flush() must not erase the busy marker of a process still running a job.
+
+        Previously, flush()'s finally block unconditionally cleared
+        _busy_workers. If a broker reconnect triggered flush() while a
+        process was still executing an accepted (e.g. long-running) job,
+        the fair scheduler would then believe that process was idle and
+        route the next task to it, queuing behind the still-running job
+        even though another process was actually free.
+        """
+        pool = asynpool.AsynPool(processes=1, synack=False, threads=False)
+        pool._state = asynpool.RUN
+        pool.maintain_pool = Mock(name='maintain_pool')
+
+        running_proc = Mock(name='running_proc')
+        running_proc.inqW_fd = 7
+        running_proc._is_alive.return_value = True
+
+        running_job = Mock(name='running_job')
+        running_job._accepted = True
+        running_job._write_to = running_proc
+        running_job._writer.return_value = None
+
+        pool._cache = {1: running_job}
+        # 99 simulates a stale marker left over from a write that was
+        # discarded/aborted during flush, whose on_job_ready() will never
+        # fire, so it must not survive the flush.
+        pool._busy_workers = {7, 99}
+        pool.outbound_buffer.clear()
+        pool._active_writers.clear()
+
+        pool.flush()
+
+        assert 7 in pool._busy_workers
+        assert 99 not in pool._busy_workers
+
