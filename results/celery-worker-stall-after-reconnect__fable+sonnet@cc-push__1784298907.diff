+        test_flush_keeps_busy_marker_for_running_job: without the fix, the
+        newly arriving job gets written to the still-busy process (fd 2)
+        instead of the idle one (fd 4), even though fd 4 was ready first
+        in line but not picked because schedule_writes cycles ready_fds
+        starting from index 0.
+        """
+        pool = asynpool.AsynPool(threads=False)
+        assert pool.sched_strategy == asynpool.SCHED_STRATEGY_FAIR
+        pool._state = asynpool.RUN
+        pool.maintain_pool = Mock(name='maintain_pool')
+
+        hub = self._get_hub()
+
+        busy_worker = Mock(name='busy_worker')
+        busy_worker.inqW_fd = 2
+        busy_worker.send_job_offset = Mock(side_effect=lambda header, HW: 5)
+
+        idle_worker = Mock(name='idle_worker')
+        idle_worker.inqW_fd = 4
+        idle_worker.send_job_offset = Mock(side_effect=lambda header, HW: 5)
+
+        hub.add_writer(2, Mock(name='writer2'), 2)
+        hub.add_writer(4, Mock(name='writer4'), 4)
