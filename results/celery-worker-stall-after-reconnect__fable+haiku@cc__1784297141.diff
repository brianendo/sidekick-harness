+    @t.skip.if_pypy
+    @patch('billiard.pool.Pool._create_worker_process')
+    def test_flush_keeps_busy_marker_for_inflight_jobs(
+            self, _create_worker_process):
+        """flush() must keep workers with in-flight jobs marked as busy.
+
+        Regression test: flush() runs from Consumer.on_close on every
+        connection-loss restart. With
+        worker_cancel_long_running_tasks_on_connection_loss disabled, a pool
+        process may still be executing a task while flush() runs. Clearing
+        _busy_workers for that process makes the fair scheduler consider it
+        free after reconnect, so the next incoming task can be written to its
+        inqueue where it sits unread until the long task completes — even
+        though other pool processes are idle.
+        """
+        pool = asynpool.AsynPool(processes=2, synack=False, threads=False)
+        pool._state = asynpool.RUN
+        pool.maintain_pool = Mock(name='maintain_pool')
+
+        busy_proc = Mock(name='busy_proc', inqW_fd=8)
+        busy_proc._is_alive.return_value = True
+
+        # An accepted job currently executing on busy_proc.
+        job = Mock(name='job')
+        job._accepted = True
+        job._write_to = busy_proc
+        job._writer.return_value = None
+
+        pool._cache = {1: job}
+        pool.outbound_buffer.clear()
+        pool._active_writers.clear()
+        pool._busy_workers.clear()
+        pool._busy_workers.add(busy_proc.inqW_fd)
+
+        pool.flush()
+
+        assert busy_proc.inqW_fd in pool._busy_workers, (
+            'flush() must not mark a worker running an in-flight task as free'
+        )
+
