+    from services.orders.api import app, VENDORS
+
+    known_vendor = sorted(VENDORS)[0]
+    client = TestClient(app)
+    # "2026/04" is intentionally excluded: a literal "/" splits the URL into
+    # extra path segments, so it 404s at routing before reaching the handler.
+    for bad_month in ("2026-13", "2026-00", "2026-4", "26-04", "not-a-month"):
+        resp = client.get(f"/vendors/{known_vendor}/statements/{bad_month}")
+        assert resp.status_code == 422, bad_month
